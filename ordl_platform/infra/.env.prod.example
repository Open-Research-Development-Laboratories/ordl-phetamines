# ORDL production profile example

POSTGRES_USER=ordl
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ordl

MINIO_ROOT_USER=ordlminio
MINIO_ROOT_PASSWORD=change-me
ORDL_STORAGE_BUCKET=ordl-artifacts

ORDL_DATABASE_URL=postgresql+psycopg://ordl:change-me@postgres:5432/ordl
ORDL_POLICY_SECRET=replace-with-strong-secret
ORDL_AUTH_SECRET=replace-with-strong-secret
ORDL_EXTENSION_SIGNING_SECRET=replace-with-strong-secret

ORDL_SECRET_BACKEND=vault
ORDL_VAULT_URL=https://vault.internal:8200
ORDL_VAULT_TOKEN_ENV_VAR=VAULT_TOKEN
ORDL_VAULT_KV_MOUNT=secret
ORDL_VAULT_KV_PATH=ordl
VAULT_TOKEN=replace-with-runtime-token
VAULT_DEV_ROOT_TOKEN_ID=root

ORDL_OIDC_ENABLED=true
ORDL_OIDC_REQUIRED=true
ORDL_OIDC_ISSUER=https://identity.example.com/realms/ordl
ORDL_OIDC_JWKS_URL=https://identity.example.com/realms/ordl/protocol/openid-connect/certs
ORDL_OIDC_AUDIENCE=ordl-platform
ORDL_ALLOW_LOCAL_TOKEN_ISSUER=false
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

VITE_ORDL_API_BASE=https://fleet.ordl.org/v1
