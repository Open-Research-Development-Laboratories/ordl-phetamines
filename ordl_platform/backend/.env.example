ORDL_APP_NAME=ORDL Platform API
ORDL_ENVIRONMENT=development
ORDL_DATABASE_URL=sqlite:///./ordl_platform.db
ORDL_AUTH_SECRET=ordl-dev-auth-secret-please-change-this-32b
ORDL_POLICY_SECRET=ordl-dev-policy-secret-please-change-this-32b
ORDL_EXTENSION_SIGNING_SECRET=ordl-dev-extension-secret-please-change-this-32b
ORDL_POLICY_TOKEN_TTL_SECONDS=300
ORDL_ACCESS_TOKEN_TTL_SECONDS=3600
ORDL_STORAGE_BACKEND=local
