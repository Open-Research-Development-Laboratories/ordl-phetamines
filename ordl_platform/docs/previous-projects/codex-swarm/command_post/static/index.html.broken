<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="classification" content="TOP SECRET//NOFORN//ORCON">
    <title>ORDL COMMAND POST | Open Research & Development Laboratories</title>
    <script src="/lib/tailwindcss@3.4.1.js"></script>
    <script src="/lib/three@0.160.0.min.js"></script>
    <script src="/lib/alpine@3.14.3.js" defer></script>
    <link rel="stylesheet" href="/font-fix.css">
    <link rel="stylesheet" href="/lib/fontawesome@6.5.1.all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&family=Orbitron:wght@400;500;600;700;800;900&display=swap');
        * { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { width: 100%; height: 100%; overflow: hidden; background: #05080a; color: #e2e8f0; font-family: 'Inter', sans-serif; }
        .font-display { font-family: 'Orbitron', sans-serif; }
        .font-mono { font-family: 'JetBrains Mono', monospace; }
        .glass-panel { background: rgba(17, 24, 32, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(0, 229, 201, 0.1); }
        .neon-text { text-shadow: 0 0 10px rgba(0, 229, 201, 0.5); }
        .btn-primary { background: linear-gradient(135deg, #00e5c9 0%, #00b4a6 100%); color: #05080a; }
        .btn-primary:hover { box-shadow: 0 0 20px rgba(0, 229, 201, 0.4); }
        [x-cloak] { display: none !important; }
    </style>
</head>
<body x-data="ordlApp()" x-init="init()" class="antialiased">
    
    <!-- AUTHENTICATION SCREEN -->
    <div x-show="!authenticated" x-cloak class="fixed inset-0 z-50 flex items-center justify-center" style="background: radial-gradient(ellipse at center, #0a0f14 0%, #05080a 100%);">
        <div class="glass-panel rounded-2xl p-8 w-full max-w-md mx-4">
            <div class="text-center mb-8">
                <div class="w-16 h-16 mx-auto mb-4 rounded-xl bg-gradient-to-br from-[#00e5c9] to-[#00b4a6] flex items-center justify-center">
                    <i class="fas fa-shield-alt text-2xl text-[#05080a]"></i>
                </div>
                <h1 class="text-2xl font-display font-bold text-[#00e5c9] mb-2">ORDL COMMAND POST</h1>
                <p class="text-slate-500 text-sm">Military-grade AI operations center</p>
            </div>
            <form @submit.prevent="login()" class="space-y-4">
                <div>
                    <label class="block text-xs text-slate-500 mb-1 font-mono uppercase">Codename</label>
                    <input x-model="authForm.codename" type="text" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-3 py-2 text-slate-200 focus:outline-none focus:border-[#00e5c9]" placeholder="Enter codename" required>
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1 font-mono uppercase">Password</label>
                    <input x-model="authForm.password" type="password" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-3 py-2 text-slate-200 focus:outline-none focus:border-[#00e5c9]" placeholder="Enter password" required>
                </div>
                <div x-show="authForm.error" x-text="authForm.error" class="text-red-400 text-sm text-center"></div>
                <button type="submit" :disabled="authForm.loading" class="w-full btn-primary py-2.5 rounded-lg font-bold text-sm flex items-center justify-center gap-2">
                    <i x-show="authForm.loading" class="fas fa-circle-notch fa-spin"></i>
                    <span x-text="authForm.loading ? 'AUTHENTICATING...' : 'ACCESS SYSTEM'"></span>
                </button>
            </form>
        </div>
    </div>

    <!-- MAIN APPLICATION -->
    <div x-show="authenticated" x-cloak class="h-screen flex">
        
        <!-- SIDEBAR -->
        <aside class="w-64 bg-[#0a0f14] border-r border-[#00e5c9]/10 flex flex-col">
            <div class="h-14 flex items-center px-4 border-b border-[#00e5c9]/10">
                <i class="fas fa-shield-alt text-[#00e5c9] mr-2"></i>
                <span class="font-display font-bold text-[#00e5c9]">ORDL</span>
                <span class="text-xs text-slate-500 ml-2">v5.0</span>
            </div>
            <nav class="flex-1 overflow-y-auto py-2">
                <template x-for="item in navItems" :key="item.id">
                    <button @click="currentView = item.id" :class="currentView === item.id ? 'bg-[#00e5c9]/10 text-[#00e5c9] border-r-2 border-[#00e5c9]' : 'text-slate-400 hover:text-slate-200 hover:bg-slate-800/50'" class="w-full flex items-center gap-3 px-4 py-2.5 transition-all text-sm">
                        <i :class="item.icon" class="w-5 text-center"></i>
                        <span class="flex-1 text-left" x-text="item.label"></span>
                        <span x-show="item.badge && item.badge !== '0'" x-text="item.badge" class="text-xs px-1.5 py-0.5 rounded bg-[#00e5c9]/20 text-[#00e5c9]"></span>
                    </button>
                </template>
            </nav>
            <div class="p-4 border-t border-[#00e5c9]/10">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-slate-800 flex items-center justify-center">
                        <i class="fas fa-user text-[#00e5c9] text-xs"></i>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div x-text="user?.codename || 'Operator'" class="text-sm font-medium text-slate-200 truncate"></div>
                        <div x-text="user?.clearance || 'UNCLASSIFIED'" class="text-xs text-[#00e5c9]"></div>
                    </div>
                    <button @click="logout()" class="text-slate-500 hover:text-red-400"><i class="fas fa-sign-out-alt"></i></button>
                </div>
            </div>
        </aside>

        <!-- MAIN CONTENT AREA -->
        <main class="flex-1 flex flex-col min-w-0 bg-[#05080a]">
            
            <!-- TOP BAR -->
            <header class="h-14 flex items-center justify-between px-6 border-b border-[#00e5c9]/10">
                <h2 x-text="navItems.find(n => n.id === currentView)?.label || currentView" class="text-lg font-display font-bold text-[#00e5c9] tracking-wider"></h2>
                <div class="flex items-center gap-4 text-sm">
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full" :class="systemStatus === 'operational' ? 'bg-emerald-400' : 'bg-amber-400'"></span>
                        <span x-text="systemStatus" class="text-slate-400 uppercase text-xs font-mono"></span>
                    </div>
                </div>
            </header>

            <!-- CONTENT VIEWS -->
            <div class="flex-1 overflow-auto p-6">

                <!-- DASHBOARD VIEW -->
                <div x-show="currentView === 'dashboard'" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                        <div class="glass-panel rounded-xl p-4">
                            <div class="text-slate-400 text-xs uppercase mb-1">Active Agents</div>
                            <div x-text="agents.filter(a => a.status === 'active').length" class="text-3xl font-display font-bold text-[#00e5c9]"></div>
                        </div>
                        <div class="glass-panel rounded-xl p-4">
                            <div class="text-slate-400 text-xs uppercase mb-1">Swarm Ops</div>
                            <div x-text="swarmOperations.filter(o => o.status === 'running').length" class="text-3xl font-display font-bold text-purple-400"></div>
                        </div>
                        <div class="glass-panel rounded-xl p-4">
                            <div class="text-slate-400 text-xs uppercase mb-1">Training Jobs</div>
                            <div x-text="trainingJobs.filter(j => j.status === 'running').length" class="text-3xl font-display font-bold text-blue-400"></div>
                        </div>
                        <div class="glass-panel rounded-xl p-4">
                            <div class="text-slate-400 text-xs uppercase mb-1">Conversations</div>
                            <div x-text="conversations.length" class="text-3xl font-display font-bold text-emerald-400"></div>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <div class="glass-panel rounded-xl p-6">
                            <h3 class="font-semibold text-slate-200 mb-4">System Status</h3>
                            <div class="space-y-3">
                                <div class="flex justify-between items-center">
                                    <span class="text-slate-400 text-sm">CPU</span>
                                    <span x-text="(system.cpu?.percent || system.cpu) + '%'" class="text-slate-200 font-mono"></span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-slate-400 text-sm">Memory</span>
                                    <span x-text="(system.memory?.percent || system.memory) + '%'" class="text-slate-200 font-mono"></span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-slate-400 text-sm">Router Latency</span>
                                    <span x-text="system.latency + 'ms'" class="text-slate-200 font-mono"></span>
                                </div>
                            </div>
                        </div>
                        <div class="glass-panel rounded-xl p-6">
                            <h3 class="font-semibold text-slate-200 mb-4">Quick Actions</h3>
                            <div class="grid grid-cols-2 gap-3">
                                <button @click="currentView = 'playground'" class="p-3 bg-slate-800/50 rounded-lg text-left hover:border-[#00e5c9]/40 border border-transparent transition-all">
                                    <i class="fas fa-flask text-[#00e5c9] mb-2"></i>
                                    <div class="text-sm font-medium text-slate-200">AI Playground</div>
                                </button>
                                <button @click="currentView = 'agents'" class="p-3 bg-slate-800/50 rounded-lg text-left hover:border-[#00e5c9]/40 border border-transparent transition-all">
                                    <i class="fas fa-robot text-purple-400 mb-2"></i>
                                    <div class="text-sm font-medium text-slate-200">Deploy Agent</div>
                                </button>
                                <button @click="currentView = 'training'" class="p-3 bg-slate-800/50 rounded-lg text-left hover:border-[#00e5c9]/40 border border-transparent transition-all">
                                    <i class="fas fa-graduation-cap text-blue-400 mb-2"></i>
                                    <div class="text-sm font-medium text-slate-200">New Training</div>
                                </button>
                                <button @click="currentView = 'swarm'" class="p-3 bg-slate-800/50 rounded-lg text-left hover:border-[#00e5c9]/40 border border-transparent transition-all">
                                    <i class="fas fa-project-diagram text-amber-400 mb-2"></i>
                                    <div class="text-sm font-medium text-slate-200">Swarm Op</div>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- PLAYGROUND VIEW -->
                <div x-show="currentView === 'playground'" class="h-full flex flex-col">
                    <div class="flex-1 overflow-auto mb-4 space-y-4" id="chat-messages">
                        <template x-for="(msg, idx) in chatMessages" :key="idx">
                            <div :class="msg.role === 'user' ? 'ml-auto' : 'mr-auto'" class="max-w-[80%]">
                                <div :class="msg.role === 'user' ? 'bg-[#00e5c9] text-[#05080a]' : 'glass-panel text-slate-200'" class="rounded-xl px-4 py-3">
                                    <div x-html="formatMessage(msg.content)" class="prose prose-invert prose-sm max-w-none"></div>
                                </div>
                            </div>
                        </template>
                        <div x-show="chatLoading" class="flex gap-2 p-4">
                            <div class="w-2 h-2 bg-[#00e5c9] rounded-full animate-bounce"></div>
                            <div class="w-2 h-2 bg-[#00e5c9] rounded-full animate-bounce" style="animation-delay: 0.1s"></div>
                            <div class="w-2 h-2 bg-[#00e5c9] rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <select x-model="config.model" class="bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200 text-sm">
                            <option value="llama-3.3-70b-versatile">Llama 3.3 70B</option>
                            <option value="llama-3.1-8b-instant">Llama 3.1 8B</option>
                        </select>
                        <input x-model="chatInput" @keydown.enter="sendMessage()" type="text" placeholder="Message..." class="flex-1 bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2 text-slate-200 focus:outline-none focus:border-[#00e5c9]">
                        <button @click="sendMessage()" :disabled="chatLoading || !chatInput.trim()" class="btn-primary px-4 py-2 rounded-lg font-semibold disabled:opacity-50">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </div>

                <!-- CONVERSATIONS VIEW -->
                <div x-show="currentView === 'conversations'">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-2xl font-display font-bold text-[#00e5c9]">Conversations</h2>
                        <button @click="createConversation()" class="btn-primary px-4 py-2 rounded-lg font-semibold text-sm">
                            <i class="fas fa-plus mr-2"></i>New
                        </button>
                    </div>
                    <div class="grid gap-3">
                        <template x-for="conv in conversations" :key="conv.id">
                            <div @click="loadConversation(conv.id)" class="glass-panel rounded-xl p-4 cursor-pointer hover:border-[#00e5c9]/40 transition-all">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-3">
                                        <i class="fas fa-comment text-[#00e5c9]"></i>
                                        <div>
                                            <h3 class="font-semibold text-slate-200" x-text="conv.title || 'Untitled'"></h3>
                                            <p class="text-xs text-slate-500" x-text="conv.model || 'llama-3.3-70b'"></p>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-3">
                                        <span class="text-xs text-slate-500" x-text="formatTime(conv.updated_at)"></span>
                                        <button @click.stop="deleteConversation(conv.id)" class="text-slate-500 hover:text-red-400"><i class="fas fa-trash"></i></button>
                                    </div>
                                </div>
                            </div>
                        </template>
                        <div x-show="conversations.length === 0" class="text-center text-slate-500 py-12">
                            <i class="fas fa-comments text-4xl mb-4 opacity-30"></i>
                            <p>No conversations yet.</p>
                        </div>
                    </div>
                </div>

                <!-- AGENTS VIEW -->
                <div x-show="currentView === 'agents'">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-2xl font-display font-bold text-[#00e5c9]">Agent Fleet</h2>
                        <button @click="showCreateAgent = true" class="btn-primary px-4 py-2 rounded-lg font-semibold text-sm">
                            <i class="fas fa-plus mr-2"></i>Deploy Agent
                        </button>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        <template x-for="agent in agents" :key="agent.id">
                            <div class="glass-panel rounded-xl p-4">
                                <div class="flex items-start justify-between mb-3">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center">
                                            <i class="fas fa-robot text-[#00e5c9]"></i>
                                        </div>
                                        <div>
                                            <h3 class="font-bold text-slate-200" x-text="agent.name"></h3>
                                            <p class="text-xs text-slate-500" x-text="agent.persona"></p>
                                        </div>
                                    </div>
                                    <span :class="agent.status === 'active' ? 'bg-emerald-500/20 text-emerald-400' : 'bg-slate-700 text-slate-400'" class="text-xs px-2 py-1 rounded" x-text="agent.status"></span>
                                </div>
                                <div class="space-y-2 text-sm">
                                    <div class="flex justify-between"><span class="text-slate-500">Model:</span><span class="text-slate-300" x-text="agent.model"></span></div>
                                    <div class="flex justify-between"><span class="text-slate-500">Clearance:</span><span class="text-[#00e5c9]" x-text="agent.clearance"></span></div>
                                    <div class="flex justify-between"><span class="text-slate-500">Tasks:</span><span class="text-slate-300" x-text="agent.tasks_completed || 0"></span></div>
                                </div>
                                <div class="mt-4 flex gap-2">
                                    <button @click="controlAgent(agent.id, agent.status === 'active' ? 'deactivate' : 'activate')" class="flex-1 py-1.5 rounded bg-slate-800 text-xs font-medium hover:bg-slate-700" x-text="agent.status === 'active' ? 'Deactivate' : 'Activate'"></button>
                                    <button @click="deleteAgent(agent.id)" class="px-3 py-1.5 rounded bg-red-500/20 text-red-400 text-xs hover:bg-red-500/30"><i class="fas fa-trash"></i></button>
                                </div>
                            </div>
                        </template>
                    </div>
                </div>

                <!-- SWARM OPS VIEW -->
                <div x-show="currentView === 'swarm'">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-2xl font-display font-bold text-[#00e5c9]">Swarm Operations</h2>
                        <button @click="showCreateSwarm = true" class="btn-primary px-4 py-2 rounded-lg font-semibold text-sm">
                            <i class="fas fa-plus mr-2"></i>New Operation
                        </button>
                    </div>
                    <div class="space-y-3">
                        <template x-for="op in swarmOperations" :key="op.id">
                            <div class="glass-panel rounded-xl p-4">
                                <div class="flex items-center justify-between mb-2">
                                    <h3 class="font-bold text-slate-200" x-text="op.name"></h3>
                                    <span :class="op.status === 'running' ? 'bg-emerald-500/20 text-emerald-400' : (op.status === 'completed' ? 'bg-blue-500/20 text-blue-400' : 'bg-slate-700 text-slate-400')" class="text-xs px-2 py-1 rounded uppercase" x-text="op.status"></span>
                                </div>
                                <p class="text-sm text-slate-400 mb-3" x-text="op.objective"></p>
                                <div class="flex items-center justify-between text-xs">
                                    <span class="text-slate-500" x-text="op.agents?.length + ' agents'"></span>
                                    <div class="flex items-center gap-2">
                                        <div class="w-24 h-1.5 bg-slate-800 rounded-full overflow-hidden">
                                            <div :style="'width:' + (op.progress || 0) + '%'" class="h-full bg-[#00e5c9] transition-all"></div>
                                        </div>
                                        <span x-text="(op.progress || 0) + '%'"></span>
                                    </div>
                                </div>
                            </div>
                        </template>
                        <div x-show="swarmOperations.length === 0" class="text-center text-slate-500 py-12">
                            <i class="fas fa-project-diagram text-4xl mb-4 opacity-30"></i>
                            <p>No swarm operations.</p>
                        </div>
                    </div>
                </div>

                <!-- TRAINING VIEW -->
                <div x-show="currentView === 'training'">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-2xl font-display font-bold text-[#00e5c9]">Training Pipeline</h2>
                        <button @click="showCreateTraining = true" class="btn-primary px-4 py-2 rounded-lg font-semibold text-sm">
                            <i class="fas fa-plus mr-2"></i>New Job
                        </button>
                    </div>
                    <div class="space-y-3">
                        <template x-for="job in trainingJobs" :key="job.id">
                            <div class="glass-panel rounded-xl p-4">
                                <div class="flex items-center justify-between mb-2">
                                    <div>
                                        <h3 class="font-bold text-slate-200" x-text="job.name"></h3>
                                        <p class="text-xs text-slate-500" x-text="job.base_model || job.model"></p>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span :class="job.status === 'running' ? 'bg-emerald-500/20 text-emerald-400' : (job.status === 'completed' ? 'bg-blue-500/20 text-blue-400' : 'bg-slate-700 text-slate-400')" class="text-xs px-2 py-1 rounded uppercase" x-text="job.status"></span>
                                        <button x-show="job.status === 'running'" @click="stopTraining(job.id)" class="text-red-400 hover:text-red-300"><i class="fas fa-stop"></i></button>
                                    </div>
                                </div>
                                <div class="flex items-center justify-between text-xs text-slate-400">
                                    <span x-text="'Progress: ' + (job.progress || 0) + '%'"></span>
                                    <span x-show="job.loss" x-text="'Loss: ' + job.loss.toFixed(4)"></span>
                                </div>
                                <div class="mt-2 w-full h-1.5 bg-slate-800 rounded-full overflow-hidden">
                                    <div :style="'width:' + (job.progress || 0) + '%'" class="h-full bg-blue-400 transition-all"></div>
                                </div>
                            </div>
                        </template>
                        <div x-show="trainingJobs.length === 0" class="text-center text-slate-500 py-12">
                            <i class="fas fa-graduation-cap text-4xl mb-4 opacity-30"></i>
                            <p>No training jobs.</p>
                        </div>
                    </div>
                </div>

                <!-- TOOLS VIEW -->
                <div x-show="currentView === 'tools'">
                    <h2 class="text-2xl font-display font-bold text-[#00e5c9] mb-6">Tools & Code</h2>
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <div class="glass-panel rounded-xl p-6">
                            <h3 class="font-semibold text-slate-200 mb-4">Code Sandbox</h3>
                            <select x-model="sandboxLanguage" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200 mb-3">
                                <option value="python">Python 3.11</option>
                                <option value="c">C23</option>
                                <option value="java">Java 21</option>
                            </select>
                            <textarea x-model="sandboxCode" rows="10" placeholder="Enter your code here..." class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-3 py-2 text-slate-200 font-mono text-sm mb-3"></textarea>
                            <button @click="executeSandbox()" class="w-full btn-primary py-2 rounded-lg font-semibold">
                                <i class="fas fa-play mr-2"></i>Execute
                            </button>
                            <div x-show="sandboxResult" class="mt-4 p-3 bg-slate-800/50 rounded-lg font-mono text-sm">
                                <pre x-text="sandboxResult" class="text-slate-300 whitespace-pre-wrap"></pre>
                            </div>
                        </div>
                        <div class="space-y-4">
                            <div class="glass-panel rounded-xl p-4">
                                <h3 class="font-semibold text-slate-200 mb-3">Built-in Tools</h3>
                                <div class="space-y-2">
                                    <div class="flex items-center gap-3 p-3 bg-slate-800/50 rounded-lg">
                                        <i class="fas fa-search text-[#00e5c9]"></i>
                                        <div class="flex-1"><div class="text-sm font-medium text-slate-200">Web Search</div></div>
                                        <span class="text-xs px-2 py-1 rounded bg-emerald-500/20 text-emerald-400">Active</span>
                                    </div>
                                    <div class="flex items-center gap-3 p-3 bg-slate-800/50 rounded-lg">
                                        <i class="fas fa-code text-[#00e5c9]"></i>
                                        <div class="flex-1"><div class="text-sm font-medium text-slate-200">Code Execution</div></div>
                                        <span class="text-xs px-2 py-1 rounded bg-emerald-500/20 text-emerald-400">Active</span>
                                    </div>
                                    <div class="flex items-center gap-3 p-3 bg-slate-800/50 rounded-lg">
                                        <i class="fas fa-file-alt text-[#00e5c9]"></i>
                                        <div class="flex-1"><div class="text-sm font-medium text-slate-200">File Analysis</div></div>
                                        <span class="text-xs px-2 py-1 rounded bg-emerald-500/20 text-emerald-400">Active</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- MCP SERVERS VIEW -->
                <div x-show="currentView === 'mcp'">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-2xl font-display font-bold text-[#00e5c9]">MCP Servers</h2>
                        <button @click="showAddMCP = true" class="btn-primary px-4 py-2 rounded-lg font-semibold text-sm">
                            <i class="fas fa-plus mr-2"></i>Add Server
                        </button>
                    </div>
                    <div class="space-y-3">
                        <template x-for="server in mcpServers" :key="server.id">
                            <div class="glass-panel rounded-xl p-4">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center"><i class="fas fa-plug text-[#00e5c9]"></i></div>
                                        <div>
                                            <h3 class="font-semibold text-slate-200" x-text="server.name"></h3>
                                            <p class="text-xs text-slate-500" x-text="server.endpoint"></p>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span :class="server.status === 'connected' ? 'bg-emerald-500/20 text-emerald-400' : 'bg-slate-700 text-slate-400'" class="text-xs px-2 py-1 rounded" x-text="server.status"></span>
                                        <button @click="connectMCP(server.id)" x-show="server.status !== 'connected'" class="text-[#00e5c9] hover:text-[#00e5c9]/80"><i class="fas fa-link"></i></button>
                                        <button @click="deleteMCP(server.id)" class="text-slate-500 hover:text-red-400"><i class="fas fa-trash"></i></button>
                                    </div>
                                </div>
                            </div>
                        </template>
                        <div x-show="mcpServers.length === 0" class="text-center text-slate-500 py-12">
                            <i class="fas fa-plug text-4xl mb-4 opacity-30"></i>
                            <p>No MCP servers configured.</p>
                        </div>
                    </div>
                </div>

                <!-- KNOWLEDGE BASE VIEW -->
                <div x-show="currentView === 'knowledge'">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-2xl font-display font-bold text-[#00e5c9]">Knowledge Base</h2>
                        <button @click="showAddKnowledge = true" class="btn-primary px-4 py-2 rounded-lg font-semibold text-sm">
                            <i class="fas fa-plus mr-2"></i>Add Entry
                        </button>
                    </div>
                    <input x-model="knowledgeSearch" type="text" placeholder="Search knowledge base..." class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2 text-slate-200 mb-4">
                    <div class="space-y-3">
                        <template x-for="entry in filteredKnowledge" :key="entry.id">
                            <div class="glass-panel rounded-xl p-4">
                                <div class="flex items-start justify-between">
                                    <div class="flex-1">
                                        <h3 class="font-semibold text-slate-200 mb-1" x-text="entry.title"></h3>
                                        <p class="text-sm text-slate-400 line-clamp-2" x-text="entry.content"></p>
                                        <div class="flex items-center gap-2 mt-2">
                                            <span class="text-xs px-2 py-1 rounded bg-slate-800 text-slate-400" x-text="entry.category"></span>
                                        </div>
                                    </div>
                                    <button @click="deleteKnowledgeEntry(entry.id)" class="text-slate-500 hover:text-red-400 ml-2"><i class="fas fa-trash"></i></button>
                                </div>
                            </div>
                        </template>
                        <div x-show="filteredKnowledge.length === 0" class="text-center text-slate-500 py-12">
                            <i class="fas fa-brain text-4xl mb-4 opacity-30"></i>
                            <p>No knowledge entries.</p>
                        </div>
                    </div>
                </div>

                <!-- FILES VIEW -->
                <div x-show="currentView === 'files'">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-2xl font-display font-bold text-[#00e5c9]">Files</h2>
                        <input type="file" @change="uploadFile($event)" class="hidden" x-ref="fileInput">
                        <button @click="$refs.fileInput.click()" class="btn-primary px-4 py-2 rounded-lg font-semibold text-sm">
                            <i class="fas fa-upload mr-2"></i>Upload
                        </button>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        <template x-for="file in files" :key="file.id">
                            <div class="glass-panel rounded-xl p-4 cursor-pointer hover:border-[#00e5c9]/40" @click="viewFile(file.id)">
                                <div class="flex items-start gap-3">
                                    <div class="w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center flex-shrink-0"><i class="fas fa-file text-[#00e5c9]"></i></div>
                                    <div class="flex-1 min-w-0">
                                        <h3 class="font-semibold text-slate-200 truncate" x-text="file.name"></h3>
                                        <p class="text-xs text-slate-500" x-text="formatFileSize(file.size)"></p>
                                    </div>
                                </div>
                            </div>
                        </template>
                        <div x-show="files.length === 0" class="col-span-full text-center text-slate-500 py-12">
                            <i class="fas fa-folder-open text-4xl mb-4 opacity-30"></i>
                            <p>No files uploaded.</p>
                        </div>
                    </div>
                </div>

                <!-- NETWORK VIEW -->
                <div x-show="currentView === 'network'">
                    <h2 class="text-2xl font-display font-bold text-[#00e5c9] mb-6">Network Operations</h2>
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <div class="glass-panel rounded-xl p-6">
                            <h3 class="font-semibold text-slate-200 mb-4">Network Status</h3>
                            <div class="space-y-3">
                                <div class="flex justify-between items-center">
                                    <span class="text-slate-400">Status</span>
                                    <span class="text-emerald-400"><i class="fas fa-check-circle mr-1"></i>Operational</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-slate-400">Active Connections</span>
                                    <span class="text-slate-200 font-mono" x-text="network.connections?.length || 0"></span>
                                </div>
                            </div>
                        </div>
                        <div class="glass-panel rounded-xl p-6">
                            <h3 class="font-semibold text-slate-200 mb-4">Adapters</h3>
                            <div class="space-y-2">
                                <template x-for="adapter in network.adapters || []" :key="adapter.name">
                                    <div class="flex items-center justify-between p-2 bg-slate-800/50 rounded">
                                        <span class="text-slate-300" x-text="adapter.name"></span>
                                        <div class="flex gap-2">
                                            <button @click="adapterKill(adapter.name)" class="text-xs px-2 py-1 rounded bg-red-500/20 text-red-400">Kill</button>
                                            <button @click="adapterRevive(adapter.name)" class="text-xs px-2 py-1 rounded bg-emerald-500/20 text-emerald-400">Revive</button>
                                        </div>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RESEARCH VIEW -->
                <div x-show="currentView === 'research'">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-2xl font-display font-bold text-[#00e5c9]">Deep Research</h2>
                        <button @click="showCreateResearch = true" class="btn-primary px-4 py-2 rounded-lg font-semibold text-sm">
                            <i class="fas fa-search mr-2"></i>New Research
                        </button>
                    </div>
                    <div class="space-y-3">
                        <template x-for="task in researchTasks" :key="task.id">
                            <div class="glass-panel rounded-xl p-4">
                                <div class="flex items-center justify-between mb-2">
                                    <h3 class="font-bold text-slate-200" x-text="task.query"></h3>
                                    <span :class="task.status === 'researching' ? 'bg-emerald-500/20 text-emerald-400' : (task.status === 'completed' ? 'bg-blue-500/20 text-blue-400' : 'bg-slate-700 text-slate-400')" class="text-xs px-2 py-1 rounded uppercase" x-text="task.status"></span>
                                </div>
                                <p class="text-sm text-slate-400" x-text="task.type + ' research'"></p>
                            </div>
                        </template>
                        <div x-show="researchTasks.length === 0" class="text-center text-slate-500 py-12">
                            <i class="fas fa-search text-4xl mb-4 opacity-30"></i>
                            <p>No research tasks.</p>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <!-- MODALS -->
    
    <!-- Create Agent Modal -->
    <div x-show="showCreateAgent" x-cloak class="fixed inset-0 z-[100] flex items-center justify-center bg-black/80" @click.self="showCreateAgent = false">
        <div class="glass-panel rounded-xl p-6 w-full max-w-md mx-4">
            <h3 class="text-xl font-bold text-[#00e5c9] mb-4">Deploy Agent</h3>
            <form @submit.prevent="createAgent()" class="space-y-4">
                <input x-model="newAgent.name" type="text" placeholder="Agent Name" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200" required>
                <input x-model="newAgent.persona" type="text" placeholder="Persona (e.g., Security Engineer)" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200" required>
                <select x-model="newAgent.model" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200">
                    <option value="llama-3.3-70b-versatile">Llama 3.3 70B</option>
                    <option value="llama-3.1-8b-instant">Llama 3.1 8B</option>
                </select>
                <select x-model="newAgent.clearance" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200">
                    <option value="UNCLASSIFIED">UNCLASSIFIED</option>
                    <option value="CONFIDENTIAL">CONFIDENTIAL</option>
                    <option value="SECRET">SECRET</option>
                    <option value="TOP SECRET">TOP SECRET</option>
                </select>
                <div class="flex justify-end gap-3">
                    <button type="button" @click="showCreateAgent = false" class="px-4 py-2 rounded-lg text-slate-400 hover:text-slate-200">Cancel</button>
                    <button type="submit" class="btn-primary px-4 py-2 rounded-lg font-semibold">Deploy</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Create Training Modal -->
    <div x-show="showCreateTraining" x-cloak class="fixed inset-0 z-[100] flex items-center justify-center bg-black/80" @click.self="showCreateTraining = false">
        <div class="glass-panel rounded-xl p-6 w-full max-w-md mx-4">
            <h3 class="text-xl font-bold text-[#00e5c9] mb-4">New Training Job</h3>
            <form @submit.prevent="createTraining()" class="space-y-4">
                <input x-model="newTraining.name" type="text" placeholder="Job Name" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200" required>
                <select x-model="newTraining.model" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200">
                    <option value="llama-3.1-8b">Llama 3.1 8B</option>
                    <option value="llama-3.3-70b">Llama 3.3 70B</option>
                </select>
                <input x-model="newTraining.max_steps" type="number" placeholder="Max Steps (default: 100)" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200">
                <div class="flex justify-end gap-3">
                    <button type="button" @click="showCreateTraining = false" class="px-4 py-2 rounded-lg text-slate-400 hover:text-slate-200">Cancel</button>
                    <button type="submit" class="btn-primary px-4 py-2 rounded-lg font-semibold">Start Training</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Create Swarm Modal -->
    <div x-show="showCreateSwarm" x-cloak class="fixed inset-0 z-[100] flex items-center justify-center bg-black/80" @click.self="showCreateSwarm = false">
        <div class="glass-panel rounded-xl p-6 w-full max-w-md mx-4">
            <h3 class="text-xl font-bold text-[#00e5c9] mb-4">New Swarm Operation</h3>
            <form @submit.prevent="createSwarmOp()" class="space-y-4">
                <input x-model="newSwarm.name" type="text" placeholder="Operation Name" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200" required>
                <textarea x-model="newSwarm.objective" placeholder="Objective" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200" rows="3" required></textarea>
                <select x-model="newSwarm.agents" multiple class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200">
                    <template x-for="agent in agents" :key="agent.id">
                        <option :value="agent.id" x-text="agent.name"></option>
                    </template>
                </select>
                <div class="flex justify-end gap-3">
                    <button type="button" @click="showCreateSwarm = false" class="px-4 py-2 rounded-lg text-slate-400 hover:text-slate-200">Cancel</button>
                    <button type="submit" class="btn-primary px-4 py-2 rounded-lg font-semibold">Launch</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Add Knowledge Modal -->
    <div x-show="showAddKnowledge" x-cloak class="fixed inset-0 z-[100] flex items-center justify-center bg-black/80" @click.self="showAddKnowledge = false">
        <div class="glass-panel rounded-xl p-6 w-full max-w-md mx-4">
            <h3 class="text-xl font-bold text-[#00e5c9] mb-4">Add Knowledge Entry</h3>
            <form @submit.prevent="addKnowledge()" class="space-y-4">
                <input x-model="newKnowledge.title" type="text" placeholder="Title" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200" required>
                <select x-model="newKnowledge.category" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200">
                    <option value="general">General</option>
                    <option value="technical">Technical</option>
                    <option value="intelligence">Intelligence</option>
                </select>
                <textarea x-model="newKnowledge.content" placeholder="Content" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200" rows="5" required></textarea>
                <div class="flex justify-end gap-3">
                    <button type="button" @click="showAddKnowledge = false" class="px-4 py-2 rounded-lg text-slate-400 hover:text-slate-200">Cancel</button>
                    <button type="submit" class="btn-primary px-4 py-2 rounded-lg font-semibold">Add</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Add MCP Modal -->
    <div x-show="showAddMCP" x-cloak class="fixed inset-0 z-[100] flex items-center justify-center bg-black/80" @click.self="showAddMCP = false">
        <div class="glass-panel rounded-xl p-6 w-full max-w-md mx-4">
            <h3 class="text-xl font-bold text-[#00e5c9] mb-4">Add MCP Server</h3>
            <form @submit.prevent="addMCP()" class="space-y-4">
                <input x-model="newMCP.name" type="text" placeholder="Server Name" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200" required>
                <select x-model="newMCP.type" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200">
                    <option value="stdio">stdio</option>
                    <option value="sse">SSE</option>
                    <option value="http">HTTP</option>
                </select>
                <input x-model="newMCP.endpoint" type="text" placeholder="Endpoint URL" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200" required>
                <div class="flex justify-end gap-3">
                    <button type="button" @click="showAddMCP = false" class="px-4 py-2 rounded-lg text-slate-400 hover:text-slate-200">Cancel</button>
                    <button type="submit" class="btn-primary px-4 py-2 rounded-lg font-semibold">Add</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Create Research Modal -->
    <div x-show="showCreateResearch" x-cloak class="fixed inset-0 z-[100] flex items-center justify-center bg-black/80" @click.self="showCreateResearch = false">
        <div class="glass-panel rounded-xl p-6 w-full max-w-md mx-4">
            <h3 class="text-xl font-bold text-[#00e5c9] mb-4">New Research Task</h3>
            <form @submit.prevent="createResearch()" class="space-y-4">
                <input x-model="newResearch.query" type="text" placeholder="Research Query" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200" required>
                <select x-model="newResearch.type" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200">
                    <option value="web_search">Web Search</option>
                    <option value="documentation">Documentation</option>
                    <option value="github">GitHub</option>
                </select>
                <div class="flex justify-end gap-3">
                    <button type="button" @click="showCreateResearch = false" class="px-4 py-2 rounded-lg text-slate-400 hover:text-slate-200">Cancel</button>
                    <button type="submit" class="btn-primary px-4 py-2 rounded-lg font-semibold">Start Research</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function ordlApp() {
            return {
                // Auth
                authenticated: false,
                user: null,
                token: localStorage.getItem('token') || '',
                authForm: { codename: '', password: '', error: '', loading: false },
                
                // Navigation
                currentView: 'dashboard',
                navItems: [
                    { id: 'dashboard', label: 'Dashboard', icon: 'fas fa-chart-line' },
                    { id: 'playground', label: 'AI Playground', icon: 'fas fa-flask' },
                    { id: 'conversations', label: 'Conversations', icon: 'fas fa-comments', badge: '0' },
                    { id: 'agents', label: 'Agent Fleet', icon: 'fas fa-robot' },
                    { id: 'swarm', label: 'Swarm Ops', icon: 'fas fa-project-diagram', badge: '0' },
                    { id: 'training', label: 'Training', icon: 'fas fa-graduation-cap', badge: '0' },
                    { id: 'tools', label: 'Tools & Code', icon: 'fas fa-tools' },
                    { id: 'mcp', label: 'MCP Servers', icon: 'fas fa-plug' },
                    { id: 'knowledge', label: 'Knowledge Base', icon: 'fas fa-brain' },
                    { id: 'files', label: 'Files', icon: 'fas fa-folder-open' },
                    { id: 'network', label: 'Network', icon: 'fas fa-network-wired' },
                    { id: 'research', label: 'Research', icon: 'fas fa-search' },
                ],
                
                // Data
                system: { cpu: 0, memory: 0, latency: 0 },
                systemStatus: 'checking',
                agents: [],
                conversations: [],
                swarmOperations: [],
                trainingJobs: [],
                researchTasks: [],
                knowledgeEntries: [],
                mcpServers: [],
                files: [],
                network: { adapters: [], connections: [] },
                
                // Chat
                chatMessages: [],
                chatInput: '',
                chatLoading: false,
                config: { model: 'llama-3.3-70b-versatile', temperature: 0.7 },
                
                // Forms
                showCreateAgent: false,
                showCreateTraining: false,
                showCreateSwarm: false,
                showAddKnowledge: false,
                showAddMCP: false,
                showCreateResearch: false,
                
                newAgent: { name: '', persona: '', model: 'llama-3.3-70b-versatile', clearance: 'SECRET' },
                newTraining: { name: '', model: 'llama-3.1-8b', max_steps: 100 },
                newSwarm: { name: '', objective: '', agents: [] },
                newKnowledge: { title: '', category: 'general', content: '' },
                newMCP: { name: '', type: 'stdio', endpoint: '' },
                newResearch: { query: '', type: 'web_search' },
                
                // Sandbox
                sandboxLanguage: 'python',
                sandboxCode: '',
                sandboxResult: '',
                knowledgeSearch: '',
                
                get authHeaders() {
                    return { 'Authorization': 'Bearer ' + this.token };
                },
                
                get filteredKnowledge() {
                    if (!this.knowledgeSearch) return this.knowledgeEntries;
                    const s = this.knowledgeSearch.toLowerCase();
                    return this.knowledgeEntries.filter(e => e.title?.toLowerCase().includes(s) || e.content?.toLowerCase().includes(s));
                },
                
                async init() {
                    if (this.token) {
                        this.authenticated = true;
                        await this.loadAll();
                    }
                    this.startPolling();
                },
                
                async loadAll() {
                    await Promise.all([
                        this.loadSystem(),
                        this.loadAgents(),
                        this.loadConversations(),
                        this.loadSwarmOps(),
                        this.loadTraining(),
                        this.loadResearch(),
                        this.loadKnowledge(),
                        this.loadMCP(),
                        this.loadFiles(),
                        this.loadNetwork()
                    ]);
                },
                
                startPolling() {
                    setInterval(() => this.loadSystem(), 5000);
                    setInterval(() => this.loadAgents(), 10000);
                    setInterval(() => this.loadTraining(), 5000);
                },
                
                async login() {
                    this.authForm.loading = true;
                    this.authForm.error = '';
                    try {
                        const res = await fetch('/api/auth/login', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(this.authForm)
                        });
                        const data = await res.json();
                        if (data.success) {
                            this.token = data.access_token;
                            localStorage.setItem('token', this.token);
                            this.authenticated = true;
                            await this.loadAll();
                        } else {
                            this.authForm.error = data.error || 'Login failed';
                        }
                    } catch (e) {
                        this.authForm.error = 'Network error';
                    }
                    this.authForm.loading = false;
                },
                
                logout() {
                    this.token = '';
                    localStorage.removeItem('token');
                    this.authenticated = false;
                    this.user = null;
                },
                
                async loadSystem() {
                    try {
                        const res = await fetch('/api/system/status', { headers: this.authHeaders });
                        if (res.ok) {
                            const data = await res.json();
                            this.system = data.metrics || {};
                            this.systemStatus = data.status;
                        }
                    } catch (e) {}
                },
                
                async loadAgents() {
                    try {
                        const res = await fetch('/api/agents', { headers: this.authHeaders });
                        if (res.ok) {
                            const data = await res.json();
                            this.agents = data.agents || [];
                        }
                    } catch (e) {}
                },
                
                async createAgent() {
                    try {
                        const res = await fetch('/api/agents', {
                            method: 'POST',
                            headers: { ...this.authHeaders, 'Content-Type': 'application/json' },
                            body: JSON.stringify(this.newAgent)
                        });
                        if (res.ok) {
                            this.showCreateAgent = false;
                            this.newAgent = { name: '', persona: '', model: 'llama-3.3-70b-versatile', clearance: 'SECRET' };
                            await this.loadAgents();
                        }
                    } catch (e) {}
                },
                
                async controlAgent(id, action) {
                    try {
                        await fetch(`/api/agents/${id}/control`, {
                            method: 'POST',
                            headers: { ...this.authHeaders, 'Content-Type': 'application/json' },
                            body: JSON.stringify({ action })
                        });
                        await this.loadAgents();
                    } catch (e) {}
                },
                
                async deleteAgent(id) {
                    if (!confirm('Delete this agent?')) return;
                    try {
                        await fetch(`/api/agents/${id}`, { method: 'DELETE', headers: this.authHeaders });
                        await this.loadAgents();
                    } catch (e) {}
                },
                
                async loadConversations() {
                    try {
                        const res = await fetch('/api/conversations', { headers: this.authHeaders });
                        if (res.ok) {
                            const data = await res.json();
                            this.conversations = data.conversations || [];
                            this.navItems.find(i => i.id === 'conversations').badge = this.conversations.length.toString();
                        }
                    } catch (e) {}
                },
                
                async createConversation() {
                    try {
                        const res = await fetch('/api/conversations', {
                            method: 'POST',
                            headers: { ...this.authHeaders, 'Content-Type': 'application/json' },
                            body: JSON.stringify({ title: 'New Conversation', model: this.config.model })
                        });
                        if (res.ok) await this.loadConversations();
                    } catch (e) {}
                },
                
                async deleteConversation(id) {
                    if (!confirm('Delete?')) return;
                    try {
                        await fetch(`/api/conversations/${id}`, { method: 'DELETE', headers: this.authHeaders });
                        await this.loadConversations();
                    } catch (e) {}
                },
                
                async loadSwarmOps() {
                    try {
                        const res = await fetch('/api/swarm/operations', { headers: this.authHeaders });
                        if (res.ok) {
                            const data = await res.json();
                            this.swarmOperations = data.operations || [];
                            this.navItems.find(i => i.id === 'swarm').badge = this.swarmOperations.filter(o => o.status === 'running').length.toString();
                        }
                    } catch (e) {}
                },
                
                async createSwarmOp() {
                    try {
                        const res = await fetch('/api/swarm/operations', {
                            method: 'POST',
                            headers: { ...this.authHeaders, 'Content-Type': 'application/json' },
                            body: JSON.stringify(this.newSwarm)
                        });
                        if (res.ok) {
                            this.showCreateSwarm = false;
                            await this.loadSwarmOps();
                        }
                    } catch (e) {}
                },
                
                async loadTraining() {
                    try {
                        const res = await fetch('/api/training/jobs', { headers: this.authHeaders });
                        if (res.ok) {
                            const data = await res.json();
                            this.trainingJobs = data.jobs || [];
                            this.navItems.find(i => i.id === 'training').badge = this.trainingJobs.filter(j => j.status === 'running').length.toString();
                        }
                    } catch (e) {}
                },
                
                async createTraining() {
                    try {
                        const res = await fetch('/api/training/jobs', {
                            method: 'POST',
                            headers: { ...this.authHeaders, 'Content-Type': 'application/json' },
                            body: JSON.stringify(this.newTraining)
                        });
                        if (res.ok) {
                            this.showCreateTraining = false;
                            await this.loadTraining();
                        }
                    } catch (e) {}
                },
                
                async stopTraining(id) {
                    try {
                        await fetch(`/api/training/jobs/${id}`, { method: 'DELETE', headers: this.authHeaders });
                        await this.loadTraining();
                    } catch (e) {}
                },
                
                async loadResearch() {
                    try {
                        const res = await fetch('/api/research/tasks', { headers: this.authHeaders });
                        if (res.ok) {
                            const data = await res.json();
                            this.researchTasks = data.tasks || [];
                        }
                    } catch (e) {}
                },
                
                async createResearch() {
                    try {
                        const res = await fetch('/api/research/tasks', {
                            method: 'POST',
                            headers: { ...this.authHeaders, 'Content-Type': 'application/json' },
                            body: JSON.stringify(this.newResearch)
                        });
                        if (res.ok) {
                            this.showCreateResearch = false;
                            await this.loadResearch();
                        }
                    } catch (e) {}
                },
                
                async loadKnowledge() {
                    try {
                        const res = await fetch('/api/knowledge', { headers: this.authHeaders });
                        if (res.ok) {
                            const data = await res.json();
                            this.knowledgeEntries = data.entries || [];
                        }
                    } catch (e) {}
                },
                
                async addKnowledge() {
                    try {
                        const res = await fetch('/api/knowledge', {
                            method: 'POST',
                            headers: { ...this.authHeaders, 'Content-Type': 'application/json' },
                            body: JSON.stringify(this.newKnowledge)
                        });
                        if (res.ok) {
                            this.showAddKnowledge = false;
                            this.newKnowledge = { title: '', category: 'general', content: '' };
                            await this.loadKnowledge();
                        }
                    } catch (e) {}
                },
                
                async deleteKnowledgeEntry(id) {
                    if (!confirm('Delete?')) return;
                    try {
                        await fetch(`/api/knowledge/${id}`, { method: 'DELETE', headers: this.authHeaders });
                        await this.loadKnowledge();
                    } catch (e) {}
                },
                
                async loadMCP() {
                    try {
                        const res = await fetch('/api/mcp/servers', { headers: this.authHeaders });
                        if (res.ok) {
                            const data = await res.json();
                            this.mcpServers = data.servers || [];
                        }
                    } catch (e) {}
                },
                
                async addMCP() {
                    try {
                        const res = await fetch('/api/mcp/servers', {
                            method: 'POST',
                            headers: { ...this.authHeaders, 'Content-Type': 'application/json' },
                            body: JSON.stringify(this.newMCP)
                        });
                        if (res.ok) {
                            this.showAddMCP = false;
                            this.newMCP = { name: '', type: 'stdio', endpoint: '' };
                            await this.loadMCP();
                        }
                    } catch (e) {}
                },
                
                async connectMCP(id) {
                    try {
                        await fetch(`/api/mcp/servers/${id}/connect`, { method: 'POST', headers: this.authHeaders });
                        await this.loadMCP();
                    } catch (e) {}
                },
                
                async deleteMCP(id) {
                    if (!confirm('Delete?')) return;
                    try {
                        await fetch(`/api/mcp/servers/${id}`, { method: 'DELETE', headers: this.authHeaders });
                        await this.loadMCP();
                    } catch (e) {}
                },
                
                async loadFiles() {
                    try {
                        const res = await fetch('/api/files', { headers: this.authHeaders });
                        if (res.ok) {
                            const data = await res.json();
                            this.files = data.files || [];
                        }
                    } catch (e) {}
                },
                
                async uploadFile(e) {
                    const file = e.target.files[0];
                    if (!file) return;
                    const formData = new FormData();
                    formData.append('file', file);
                    try {
                        const res = await fetch('/api/files/upload', {
                            method: 'POST',
                            headers: this.authHeaders,
                            body: formData
                        });
                        if (res.ok) await this.loadFiles();
                    } catch (e) {}
                },
                
                viewFile(id) {
                    window.open(`/api/files/${id}/download`, '_blank');
                },
                
                async loadNetwork() {
                    try {
                        const res = await fetch('/api/network/status', { headers: this.authHeaders });
                        if (res.ok) {
                            const data = await res.json();
                            this.network = data;
                        }
                    } catch (e) {}
                },
                
                async adapterKill(iface) {
                    try {
                        await fetch(`/api/network/adapters/${iface}/kill`, { method: 'POST', headers: this.authHeaders });
                        await this.loadNetwork();
                    } catch (e) {}
                },
                
                async adapterRevive(iface) {
                    try {
                        await fetch(`/api/network/adapters/${iface}/revive`, { method: 'POST', headers: this.authHeaders });
                        await this.loadNetwork();
                    } catch (e) {}
                },
                
                async executeSandbox() {
                    this.sandboxResult = 'Executing...';
                    try {
                        const res = await fetch('/api/sandbox/execute', {
                            method: 'POST',
                            headers: { ...this.authHeaders, 'Content-Type': 'application/json' },
                            body: JSON.stringify({ language: this.sandboxLanguage, code: this.sandboxCode })
                        });
                        const data = await res.json();
                        this.sandboxResult = data.output || data.error || 'No output';
                    } catch (e) {
                        this.sandboxResult = 'Error: ' + e.message;
                    }
                },
                
                async sendMessage() {
                    if (!this.chatInput.trim() || this.chatLoading) return;
                    const msg = this.chatInput;
                    this.chatMessages.push({ role: 'user', content: msg });
                    this.chatInput = '';
                    this.chatLoading = true;
                    try {
                        const res = await fetch('/api/chat', {
                            method: 'POST',
                            headers: { ...this.authHeaders, 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                model: this.config.model,
                                messages: [{ role: 'user', content: msg }]
                            })
                        });
                        const data = await res.json();
                        this.chatMessages.push({ role: 'assistant', content: data.choices?.[0]?.message?.content || 'No response' });
                    } catch (e) {
                        this.chatMessages.push({ role: 'assistant', content: 'Error: ' + e.message });
                    }
                    this.chatLoading = false;
                },
                
                formatMessage(text) {
                    return text?.replace(/\n/g, '<br>') || '';
                },
                
                formatTime(time) {
                    if (!time) return '';
                    const d = new Date(time);
                    return d.toLocaleString();
                },
                
                formatFileSize(bytes) {
                    if (!bytes) return '0 B';
                    const sizes = ['B', 'KB', 'MB', 'GB'];
                    const i = Math.floor(Math.log(bytes) / Math.log(1024));
                    return Math.round(bytes / Math.pow(1024, i) * 100) / 100 + ' ' + sizes[i];
                }
            }
        }
    </script>
</body>
</html>
