# ORDL Command Post v5.0.0 - Environment Configuration
# Copy this file to .env and customize as needed
# Classification: TOP SECRET//NOFORN

# =============================================================================
# Core Configuration
# =============================================================================

# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-secret-key-here-change-in-production

# Legacy API Token (for backward compatibility)
NEXUS_TOKEN=REPLACE_WITH_ENV_NEXUS_TOKEN

# Router URL (AI inference endpoint)
ROUTER_URL=http://localhost:18000

# =============================================================================
# Data Directories
# =============================================================================

DATA_DIR=/opt/codex-swarm/command-post/data
UPLOADS_DIR=/opt/codex-swarm/command-post/uploads
MODELS_DIR=/opt/codex-swarm/command-post/models
DATASETS_DIR=/opt/codex-swarm/command-post/datasets
LOGS_DIR=/opt/codex-swarm/command-post/logs

# =============================================================================
# GPU Configuration (Optional)
# =============================================================================

# CUDA device selection (auto, cpu, cuda, cuda:0, cuda:1, etc.)
CUDA_VISIBLE_DEVICES=0
TRAINING_DEVICE=auto

# =============================================================================
# External API Keys (Optional)
# =============================================================================

# SerpAPI for search functionality
SERPAPI_KEY=your-serpapi-key-here

# HuggingFace token for model downloads
HF_TOKEN=your-huggingface-token-here

# Groq API key (if using Groq directly)
GROQ_API_KEY=your-groq-api-key-here

# =============================================================================
# Network Configuration
# =============================================================================

# WebSocket server settings
WS_HOST=0.0.0.0
WS_PORT=18011

# MCP server settings
MCP_HOST=0.0.0.0
MCP_PORT=18080

# API server port
API_PORT=18010

# =============================================================================
# Security Settings
# =============================================================================

# Enable/disable features
ENABLE_SANDBOX=true
ENABLE_TRAINING=true
ENABLE_NETWORK_OPS=true

# Rate limiting
RATE_LIMIT_PER_MINUTE=200

# =============================================================================
# Proxy Configuration (Optional)
# =============================================================================

# Comma-separated list of proxies for web scraping
PROXY_LIST=

# =============================================================================
# Development Settings
# =============================================================================

# Debug mode (NEVER enable in production)
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
