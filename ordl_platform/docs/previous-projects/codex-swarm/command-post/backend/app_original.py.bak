@app.route('/api/backup', methods=['POST'])
@require_auth
def create_backup():
    """Create full database backup"""
    backup_id = f"backup-{datetime.utcnow().strftime('%Y%m%d-%H%M%S')}"
    backup_path = os.path.join(DATA_DIR, f'{backup_id}.db')
    
    # Copy database
    import shutil
    shutil.copy2(DB_PATH, backup_path)
    
    return jsonify({
        'success': True,
        'backup_id': backup_id,
        'backup_path': backup_path,
        'size': os.path.getsize(backup_path),
        'created_at': datetime.utcnow().isoformat()
    })

# =============================================================================
# STATIC FILE SERVING
# =============================================================================
@app.route('/')
def serve_index():
    return send_from_directory(STATIC_FOLDER, 'index.html')

@app.route('/lib/<path:path>')
def serve_lib(path):
    return send_from_directory(os.path.join(STATIC_FOLDER, 'lib'), path)

@app.route('/<path:path>')
def serve_static(path):
    file_path = os.path.join(STATIC_FOLDER, path)
    if os.path.exists(file_path) and os.path.isfile(file_path):
        return send_from_directory(STATIC_FOLDER, path)
    return send_from_directory(STATIC_FOLDER, 'index.html')

# =============================================================================
# ERROR HANDLERS
# =============================================================================
@app.errorhandler(404)
def not_found(e):
    return jsonify({'error': 'Not found'}), 404

@app.errorhandler(500)
def internal_error(e):
    log_system_event('error', 'server', f'Internal error: {str(e)}')
    return jsonify({'error': 'Internal server error'}), 500

@app.errorhandler(429)
def rate_limit(e):
    return jsonify({'error': 'Rate limit exceeded'}), 429

