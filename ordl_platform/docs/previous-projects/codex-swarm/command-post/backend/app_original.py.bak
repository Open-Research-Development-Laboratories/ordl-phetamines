@app.route('/api/research/tasks/<task_id>/action', methods=['POST'])
@require_auth
def research_task_action(task_id):
    """Perform actions on research task (continue, drop, share)"""
    if task_id not in research_tasks:
        return jsonify({'error': 'Task not found'}), 404
    
    data = request.get_json()
    action = data.get('action')
    task = research_tasks[task_id]
    
    if action == 'continue':
        # Continue research with new sources
        new_url = data.get('url')
        if new_url:
            def continue_research():
                task['status'] = 'researching'
                scraped = scrape_website(new_url)
                task['scraped_data'].append(scraped)
                
                if 'error' not in scraped:
                    task['sources'].append({
                        'url': scraped['url'],
                        'title': scraped['title'],
                        'relevance': 0.8
                    })
                    task['findings'].append(f"Additional: {scraped['title']} - {scraped['description'][:150]}...")
                
                task['status'] = 'completed'
                task['completed_at'] = datetime.utcnow().isoformat()
                
                # Update DB
                conn = sqlite3.connect(DB_PATH)
                cursor = conn.cursor()
                cursor.execute('''
                    UPDATE research_tasks SET sources = ?, findings = ?, status = ?, completed_at = ?
                    WHERE id = ?
                ''', (json.dumps(task['sources']), json.dumps(task['findings']), 
                      'completed', task['completed_at'], task_id))
                conn.commit()
                conn.close()
            
            threading.Thread(target=continue_research, daemon=True).start()
    
    elif action == 'drop':
        task['status'] = 'dropped'
        task['dropped_at'] = datetime.utcnow().isoformat()
    
    elif action == 'share':
        # Generate shareable summary
        share_data = {
            'title': f"Research: {task['query']}",
            'sources': len(task['sources']),
            'summary': task.get('summary', '')[:500],
            'shared_at': datetime.utcnow().isoformat()
        }
        task['share_data'] = share_data
    
    return jsonify({'success': True, 'task': task})

@app.route('/api/research/tasks/<task_id>', methods=['DELETE'])
@require_auth
def delete_research_task(task_id):
    """Delete a research task"""
    if task_id in research_tasks:
        del research_tasks[task_id]
        
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        cursor.execute('DELETE FROM research_tasks WHERE id = ?', (task_id,))
        conn.commit()
        conn.close()
    
    return jsonify({'success': True})

