@app.route('/api/knowledge/search', methods=['POST'])
@require_auth
def search_knowledge():
    """Search knowledge base with AI enhancement"""
    data = request.get_json()
    query = data.get('query', '')
    
    # Simple keyword search
    results = []
    for entry in knowledge_base.values():
        score = 0
        query_words = query.lower().split()
        
        for word in query_words:
            if word in entry['title'].lower():
                score += 10
            if word in entry['content'].lower():
                score += 5
            if word in [t.lower() for t in entry['tags']]:
                score += 8
        
        if score > 0:
            results.append({**entry, 'relevance_score': score})
    
    results.sort(key=lambda x: x['relevance_score'], reverse=True)
    
    # Use AI to generate answer if we have results
    answer = None
    if results:
        context = "\n\n".join([f"Title: {r['title']}\nContent: {r['content'][:500]}" for r in results[:3]])
        prompt = f"Based on the following knowledge base entries, answer: {query}\n\n{context}"
        
        ai_result = generate_with_ai(prompt, 'llama-3.3-70b-versatile', 
                                     'You are a helpful assistant. Answer based on the provided context.')
        if ai_result['success']:
            answer = ai_result['content']
    
    return jsonify({
        'query': query,
        'results': results[:10],
        'ai_answer': answer,
        'total_found': len(results)
    })

