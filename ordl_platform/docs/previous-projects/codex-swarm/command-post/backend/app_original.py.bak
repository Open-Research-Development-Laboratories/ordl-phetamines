@app.route('/api/tools', methods=['POST'])
@require_auth
def create_tool():
    """Create a custom tool"""
    data = request.get_json()
    tool_id = f"tool-{str(uuid.uuid4())[:8]}"
    
    tool = {
        'id': tool_id,
        'name': data.get('name', 'Untitled Tool'),
        'description': data.get('description', ''),
        'code': data.get('code', ''),
        'language': data.get('language', 'python'),
        'created_at': datetime.utcnow().isoformat(),
        'usage_count': 0
    }
    
    tools_registry[tool_id] = tool
    
    # Save to DB
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('''
        INSERT INTO tools (id, name, description, code, language, created_at)
        VALUES (?, ?, ?, ?, ?, ?)
    ''', (tool_id, tool['name'], tool['description'], tool['code'], 
          tool['language'], tool['created_at']))
    conn.commit()
    conn.close()
    
    log_system_event('info', 'tools', f"Created custom tool: {tool['name']}", {'tool_id': tool_id})
    
    return jsonify({'success': True, 'tool': tool}), 201

@app.route('/api/tools/<tool_id>', methods=['GET'])
@require_auth
def get_tool(tool_id):
    """Get tool details"""
    if tool_id in tools_registry:
        return jsonify(tools_registry[tool_id])
    return jsonify({'error': 'Tool not found'}), 404

@app.route('/api/tools/<tool_id>', methods=['PUT'])
@require_auth
def update_tool(tool_id):
    """Update custom tool"""
    if tool_id not in tools_registry:
        return jsonify({'error': 'Tool not found'}), 404
    
    data = request.get_json()
    tool = tools_registry[tool_id]
    
    tool['name'] = data.get('name', tool['name'])
    tool['description'] = data.get('description', tool['description'])
    tool['code'] = data.get('code', tool['code'])
    tool['updated_at'] = datetime.utcnow().isoformat()
    
    # Update DB
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('''
        UPDATE tools SET name = ?, description = ?, code = ? WHERE id = ?
    ''', (tool['name'], tool['description'], tool['code'], tool_id))
    conn.commit()
    conn.close()
    
    return jsonify({'success': True, 'tool': tool})

@app.route('/api/tools/<tool_id>', methods=['DELETE'])
@require_auth
def delete_tool(tool_id):
    """Delete custom tool"""
    if tool_id in tools_registry:
        del tools_registry[tool_id]
        
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        cursor.execute('DELETE FROM tools WHERE id = ?', (tool_id,))
        conn.commit()
        conn.close()
    
    return jsonify({'success': True})

@app.route('/api/tools/<tool_id>/execute', methods=['POST'])
@require_auth
def execute_tool(tool_id):
    """Execute a custom tool"""
    if tool_id not in tools_registry:
        return jsonify({'error': 'Tool not found'}), 404
    
    tool = tools_registry[tool_id]
    data = request.get_json()
    
    # Increment usage count
    tool['usage_count'] += 1
    
    # Execute Python code
    if tool['language'] == 'python':
        try:
            # Create restricted environment
            allowed_builtins = {
                'len': len, 'str': str, 'int': int, 'float': float,
                'list': list, 'dict': dict, 'range': range, 'enumerate': enumerate,
                'zip': zip, 'map': map, 'filter': filter, 'sum': sum,
                'min': min, 'max': max, 'abs': abs, 'round': round,
                'json': json, 're': re, 'datetime': datetime,
                'print': lambda x: x  # Capture print output
            }
            
            exec_globals = {'__builtins__': allowed_builtins, 'input_data': data.get('input', {})}
            exec_locals = {}
            
            # Capture output
            old_stdout = sys.stdout
            sys.stdout = io.StringIO()
            
            exec(tool['code'], exec_globals, exec_locals)
            
            output = sys.stdout.getvalue()
            sys.stdout = old_stdout
            
            result = exec_locals.get('result', output or 'Executed successfully')
            
            return jsonify({
                'success': True,
                'result': result,
                'tool': tool['name'],
                'execution_time': datetime.utcnow().isoformat()
            })
        
        except Exception as e:
            sys.stdout = old_stdout
            return jsonify({'success': False, 'error': str(e)}), 500
    
    return jsonify({'error': 'Unsupported language'}), 400

