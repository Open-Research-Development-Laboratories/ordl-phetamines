# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
def require_auth(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        auth_header = request.headers.get('Authorization', '')
        if not auth_header.startswith('Bearer '):
            log_system_event('warning', 'auth', 'Missing authorization header', 
                           {'ip': request.remote_addr, 'path': request.path})
            return jsonify({"error": "Missing authorization"}), 401
        token = auth_header.split(' ')[1]
        if token != BEARER_TOKEN:
            log_system_event('warning', 'auth', 'Invalid token attempted',
                           {'ip': request.remote_addr, 'token_prefix': token[:20]})
            return jsonify({"error": "Invalid token"}), 403
        return f(*args, **kwargs)
    return decorated

def require_clearance(clearance_level):
    """Decorator to require specific clearance level"""
    def decorator(f):
        @wraps(f)
        def decorated(*args, **kwargs):
            # Check if user has required clearance
            # In production, this would check against user session
            return f(*args, **kwargs)
        return decorated
    return decorator

# =============================================================================
# SECURITY HEADERS
# =============================================================================
@app.after_request
def add_security_headers(response):
    response.headers['X-Frame-Options'] = 'DENY'
    response.headers['X-Content-Type-Options'] = 'nosniff'
    response.headers['X-XSS-Protection'] = '1; mode=block'
    response.headers['Strict-Transport-Security'] = 'max-age=31536000; includeSubDomains'
    response.headers['Content-Security-Policy'] = (
        "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; "
        "style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; "
        "font-src 'self' https://fonts.gstatic.com; connect-src 'self' *; "
        "img-src 'self' data: blob:; media-src 'self'; frame-ancestors 'none';"
    )
    response.headers['Referrer-Policy'] = 'strict-origin-when-cross-origin'
    response.headers['Permissions-Policy'] = 'camera=(), microphone=(), geolocation=()'
    return response

# =============================================================================
# REAL WEB SCRAPING
# =============================================================================
def scrape_website(url):
    """Actually scrape a website and return structured data"""
    try:
        if not url.startswith('http'):
            url = 'https://' + url
        
        headers = {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
            'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
            'Accept-Language': 'en-US,en;q=0.5',
            # Don't set Accept-Encoding - let requests handle it automatically
            'DNT': '1',
            'Connection': 'keep-alive',
        }
        
        response = requests.get(url, headers=headers, timeout=15, allow_redirects=True, verify=False)
        # Ensure proper encoding
        if response.encoding is None:
            response.encoding = 'utf-8'
        response.raise_for_status()
        
        html = response.text
        
        # Extract title
        title_match = re.search(r'<title[^>]*>([^<]+)</title>', html, re.IGNORECASE | re.DOTALL)
        title = re.sub(r'\s+', ' ', title_match.group(1).strip()) if title_match else 'No title found'
        
        # Extract meta description
        desc_match = re.search(r'<meta[^>]*name=["\']description["\'][^>]*content=["\']([^"\']+)', html, re.IGNORECASE)
        if not desc_match:
            desc_match = re.search(r'<meta[^>]*content=["\']([^"\']+)["\'][^>]*name=["\']description["\']', html, re.IGNORECASE)
        if not desc_match:
            desc_match = re.search(r'<meta[^>]*property=["\']og:description["\'][^>]*content=["\']([^"\']+)', html, re.IGNORECASE)
        description = desc_match.group(1) if desc_match else 'No description found'
        
        # Extract headings
        headings = re.findall(r'<h([1-3])[^>]*>([^<]+)</h\1>', html, re.IGNORECASE | re.DOTALL)
        headings = [re.sub(r'\s+', ' ', h[1].strip()) for h in headings[:10]]
        
        # Extract links with titles
        links = []
        link_matches = re.findall(r'<a[^>]*href=["\'](https?://[^"\']+)["\'][^>]*>([^<]*)</a>', html, re.IGNORECASE | re.DOTALL)
        for href, text in link_matches[:15]:
            links.append({'url': href, 'title': re.sub(r'\s+', ' ', text.strip()) or 'Untitled'})
        
        # Extract text content
        text = re.sub(r'<[^>]+>', ' ', html)
        text = re.sub(r'\s+', ' ', text).strip()
        word_count = len(text.split())
        
        # Extract main content area (heuristic)
        content_preview = text[:1000] if len(text) > 1000 else text
        
        log_system_event('info', 'web_scrape', f'Successfully scraped {url}', 
                        {'title': title[:100], 'word_count': word_count})
        
        return {
            'url': url,
            'title': title,
            'description': description,
            'headings': headings,
            'links': links,
            'word_count': word_count,
            'content_preview': content_preview,
            'status_code': response.status_code,
            'content_type': response.headers.get('Content-Type', 'unknown'),
            'scraped_at': datetime.utcnow().isoformat()
        }
    except Exception as e:
        log_system_event('error', 'web_scrape', f'Failed to scrape {url}', {'error': str(e)})
        return {
            'url': url,
            'error': str(e),
            'scraped_at': datetime.utcnow().isoformat()
        }

# =============================================================================
# REAL AI GENERATION
# =============================================================================
def generate_with_ai(prompt, model='llama-3.3-70b-versatile', system_prompt=None, temperature=0.7, max_tokens=4096):
    """Generate real AI response using the router (which uses Groq)"""
    try:
        messages = []
        if system_prompt:
            messages.append({'role': 'system', 'content': system_prompt})
        messages.append({'role': 'user', 'content': prompt})
        
        response = requests.post(
            f'{ROUTER_URL}/v1/responses',
            headers={'Authorization': f'Bearer {BEARER_TOKEN}'},
            json={
                'model': model,
                'input': messages,
                'temperature': temperature,
                'max_tokens': max_tokens
            },
            timeout=120
        )
        
        if response.status_code == 200:
            data = response.json()
            return {
                'success': True,
                'content': data.get('response', 'No response'),
                'model': data.get('model', model),
                'latency_ms': data.get('latency_ms'),
                'tokens_used': data.get('usage', {}).get('total_tokens', 0)
            }
        else:
            error_msg = f'Router Error: {response.status_code}'
            try:
                error_detail = response.json()
                error_msg += f' - {error_detail.get("error", "")}'
            except:
                pass
            log_system_event('error', 'ai_generation', error_msg)
            return {'success': False, 'error': error_msg}
    except Exception as e:
        log_system_event('error', 'ai_generation', f'AI generation failed: {str(e)}')
        return {'success': False, 'error': str(e)}

def stream_ai_response(prompt, model='llama-3.3-70b-versatile', system_prompt=None, temperature=0.7):
    """Stream AI response for real-time updates"""
    try:
        messages = []
        if system_prompt:
            messages.append({'role': 'system', 'content': system_prompt})
        messages.append({'role': 'user', 'content': prompt})
        
        response = requests.post(
            f'{ROUTER_URL}/v1/responses',
            headers={'Authorization': f'Bearer {BEARER_TOKEN}'},
            json={
                'model': model,
                'input': messages,
                'temperature': temperature,
                'max_tokens': 4096,
                'stream': True
            },
            timeout=120,
            stream=True
        )
        
        if response.status_code == 200:
            for line in response.iter_lines():
                if line:
                    try:
                        data = json.loads(line.decode('utf-8').replace('data: ', ''))
                        if 'content' in data:
                            yield f"data: {json.dumps({'content': data['content']})}\n\n"
                    except:
                        pass
            yield f"data: {json.dumps({'done': True})}\n\n"
        else:
            yield f"data: {json.dumps({'error': f'Router Error: {response.status_code}'})}\n\n"
    except Exception as e:
        yield f"data: {json.dumps({'error': str(e)})}\n\n"

# =============================================================================
# HEALTH & STATUS
# =============================================================================
@app.route('/health')
def health():
    try:
        router_status = 'unknown'
        try:
            r = requests.get(f'{ROUTER_URL}/health', timeout=2)
            router_status = 'healthy' if r.status_code == 200 else 'degraded'
        except:
            router_status = 'unreachable'
        
        cpu_percent = psutil.cpu_percent(interval=0.1)
        memory = psutil.virtual_memory()
        disk = psutil.disk_usage('/')
        
        # Check database
        db_status = 'healthy'
        try:
            conn = sqlite3.connect(DB_PATH)
            conn.execute('SELECT 1')
            conn.close()
        except:
            db_status = 'degraded'
        
        return jsonify({
            'status': 'healthy' if router_status == 'healthy' and db_status == 'healthy' else 'degraded',
            'version': '4.0.0',
            'timestamp': datetime.utcnow().isoformat(),
            'system': {
                'cpu_percent': cpu_percent,
                'memory_percent': memory.percent,
                'memory_available_gb': round(memory.available / (1024**3), 2),
                'disk_percent': disk.percent,
                'disk_free_gb': round(disk.free / (1024**3), 2)
            },
            'dependencies': {
                'router': router_status,
                'database': db_status
            }
        })
    except Exception as e:
        return jsonify({'status': 'unhealthy', 'error': str(e)}), 503

@app.route('/api/system/status')
@require_auth
def system_status():
    try:
        now = time.time()
        request_count['per_minute'] = [t for t in request_count['per_minute'] if now - t < 60]
        
        cpu = psutil.cpu_percent(interval=0.1)
        memory = psutil.virtual_memory()
        disk = psutil.disk_usage('/')
        net_io = psutil.net_io_counters()
        
        # Get network interfaces
        interfaces = []
        for name, addrs in psutil.net_if_addrs().items():
            if name != 'lo':
                for addr in addrs:
                    if addr.family == 2:  # IPv4
                        interfaces.append({'name': name, 'address': addr.address})
        
        # Get process info
        process = psutil.Process()
        process_info = {
            'pid': process.pid,
            'cpu_percent': process.cpu_percent(),
            'memory_mb': round(process.memory_info().rss / (1024*1024), 2),
            'threads': process.num_threads(),
            'connections': len(process.connections())
        }
        
        # Check router
        router_latency = None
        router_status = 'offline'
        try:
            start = time.time()
            r = requests.get(f'{ROUTER_URL}/health', timeout=3)
            router_latency = round((time.time() - start) * 1000, 2)
            router_status = 'online' if r.status_code == 200 else 'degraded'
        except:
            pass
        
        # Get DB stats
        db_stats = {'agents': 0, 'training_jobs': 0, 'research_tasks': 0}
        try:
            conn = sqlite3.connect(DB_PATH)
            cursor = conn.cursor()
            cursor.execute('SELECT COUNT(*) FROM agents')
            db_stats['agents'] = cursor.fetchone()[0]
            cursor.execute('SELECT COUNT(*) FROM training_jobs')
            db_stats['training_jobs'] = cursor.fetchone()[0]
            cursor.execute('SELECT COUNT(*) FROM research_tasks')
            db_stats['research_tasks'] = cursor.fetchone()[0]
            conn.close()
        except:
            pass
        
        return jsonify({
            'status': 'operational' if router_status == 'online' else 'degraded',
            'timestamp': datetime.utcnow().isoformat(),
            'version': '4.0.0',
            'metrics': {
                'cpu': {'percent': cpu, 'cores': psutil.cpu_count(), 'freq': psutil.cpu_freq()._asdict() if psutil.cpu_freq() else None},
                'memory': {
                    'percent': memory.percent,
                    'used_gb': round(memory.used / (1024**3), 2),
                    'total_gb': round(memory.total / (1024**3), 2),
                    'available_gb': round(memory.available / (1024**3), 2)
                },
                'storage': {
                    'percent': disk.percent,
                    'used_gb': round(disk.used / (1024**3), 2),
                    'total_gb': round(disk.total / (1024**3), 2)
                },
                'network': {
                    'bytes_sent': net_io.bytes_sent,
                    'bytes_recv': net_io.bytes_recv,
                    'packets_sent': net_io.packets_sent,
                    'packets_recv': net_io.packets_recv,
                    'interfaces': interfaces
                },
                'process': process_info,
                'agents': {
                    'total': len(agents_db),
                    'active': sum(1 for a in agents_db.values() if a['status'] == 'active')
                },
                'requests': {
                    'total': request_count['total'],
                    'per_minute': len(request_count['per_minute'])
                },
                'database': db_stats
            },
            'router': {
                'status': router_status,
                'latency_ms': router_latency,
                'url': ROUTER_URL
            }
        })
    except Exception as e:
        return jsonify({'status': 'error', 'error': str(e)}), 500

@app.route('/api/system/events')
@require_auth
def get_system_events():
    """Get system events log"""
    try:
        limit = request.args.get('limit', 100, type=int)
        level = request.args.get('level', None)
        
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        
        if level:
            cursor.execute('''
                SELECT * FROM system_events 
                WHERE level = ?
                ORDER BY timestamp DESC 
                LIMIT ?
            ''', (level, limit))
        else:
            cursor.execute('''
                SELECT * FROM system_events 
                ORDER BY timestamp DESC 
                LIMIT ?
            ''', (limit,))
        
        events = []
        for row in cursor.fetchall():
            events.append({
                'id': row[0],
                'timestamp': row[1],
                'level': row[2],
                'component': row[3],
                'message': row[4],
                'details': json.loads(row[5]) if row[5] else None
            })
        
        conn.close()
        return jsonify({'events': events, 'count': len(events)})
    except Exception as e:
        return jsonify({'error': str(e)}), 500

