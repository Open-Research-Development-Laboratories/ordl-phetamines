@app.route('/api/tools/code_execution', methods=['POST'])
@require_auth
def code_execution_tool():
    """Execute Python code in sandboxed environment"""
    data = request.get_json()
    code = data.get('code', '')
    
    if not code:
        return jsonify({'error': 'No code provided'}), 400
    
    try:
        # Security: Check for dangerous imports/operations
        dangerous_patterns = [
            r'import\s+os\s+as',
            r'__import__\s*\(',
            r'subprocess',
            r'eval\s*\(',
            r'exec\s*\(',
            r'open\s*\(',
            r'file\s*=',
            r'system\s*\(',
            r'popen',
            r'input\s*\(',
            r'raw_input',
        ]
        
        for pattern in dangerous_patterns:
            if re.search(pattern, code, re.IGNORECASE):
                return jsonify({'error': f'Security violation detected: {pattern}'}), 403
        
        # Create restricted environment
        allowed_imports = ['math', 'random', 'datetime', 'json', 're', 'statistics', 'itertools', 'collections', 'functools']
        
        def safe_import(name, *args, **kwargs):
            if name not in allowed_imports:
                raise ImportError(f"Import of '{name}' not allowed")
            return __import__(name, *args, **kwargs)
        
        allowed_builtins = {
            'len': len, 'str': str, 'int': int, 'float': float,
            'list': list, 'dict': dict, 'tuple': tuple, 'set': set,
            'range': range, 'enumerate': enumerate, 'zip': zip,
            'map': map, 'filter': filter, 'sum': sum, 'any': any, 'all': all,
            'min': min, 'max': max, 'abs': abs, 'round': round,
            'pow': pow, 'divmod': divmod, 'chr': chr, 'ord': ord,
            'bin': bin, 'hex': hex, 'oct': oct,
            'sorted': sorted, 'reversed': reversed,
            'isinstance': isinstance, 'hasattr': hasattr, 'getattr': getattr,
            'print': lambda *args, **kwargs: None,  # Disable print for security
            '__import__': safe_import,
            'True': True, 'False': False, 'None': None
        }
        
        exec_globals = {'__builtins__': allowed_builtins}
        exec_locals = {}
        
        # Capture output
        stdout_capture = io.StringIO()
        
        with contextlib.redirect_stdout(stdout_capture):
            exec(code, exec_globals, exec_locals)
        
        output = stdout_capture.getvalue()
        
        # Get result variable if defined
        result_value = exec_locals.get('result', None)
        
        return jsonify({
            'success': True,
            'output': output,
            'result': result_value,
            'locals': {k: str(v)[:1000] for k, v in exec_locals.items() if not k.startswith('_')},
            'execution_time': datetime.utcnow().isoformat()
        })
    
    except Exception as e:
        import traceback
        return jsonify({
            'success': False,
            'error': str(e),
            'traceback': traceback.format_exc()
        }), 500

@app.route('/api/tools/file_analysis', methods=['POST'])
@require_auth
def file_analysis_tool():
    """Analyze uploaded files"""
    data = request.get_json()
    file_id = data.get('file_id')
    
    if not file_id or file_id not in file_uploads:
        return jsonify({'error': 'File not found'}), 404
    
    file_info = file_uploads[file_id]
    
    # Perform analysis based on file type
    analysis = {
        'file_name': file_info['name'],
        'file_size': file_info['size'],
        'file_type': file_info['type'],
        'uploaded_at': file_info['uploaded_at'],
        'content_preview': file_info.get('content_preview', '')[:500]
    }
    
    # Text file analysis
    if file_info['type'].startswith('text/') or file_info['name'].endswith(('.py', '.js', '.json', '.md', '.txt', '.yaml', '.yml')):
        content = file_info.get('content_preview', '')
        lines = content.split('\n')
        analysis['line_count'] = len(lines)
        analysis['word_count'] = len(content.split())
        analysis['char_count'] = len(content)
        
        # Code-specific analysis
        if file_info['name'].endswith('.py'):
            analysis['language'] = 'Python'
            analysis['function_count'] = len(re.findall(r'^def\s+', content, re.MULTILINE))
            analysis['class_count'] = len(re.findall(r'^class\s+', content, re.MULTILINE))
            analysis['import_count'] = len(re.findall(r'^(import|from)\s+', content, re.MULTILINE))
        elif file_info['name'].endswith('.js'):
            analysis['language'] = 'JavaScript'
            analysis['function_count'] = len(re.findall(r'function\s+', content))
    
    # Image analysis (basic)
    elif file_info['type'].startswith('image/'):
        analysis['image_type'] = file_info['type']
        # In production, would use PIL to get dimensions
        analysis['note'] = 'Image analysis requires PIL library'
    
    return jsonify(analysis)

@app.route('/api/tools/system_info', methods=['GET'])
@require_auth
def system_info_tool():
    """Get detailed system information"""
    try:
        boot_time = datetime.fromtimestamp(psutil.boot_time()).isoformat()
        cpu_freq = psutil.cpu_freq()
        
        # Get detailed CPU info
        cpu_info = {
            'physical_cores': psutil.cpu_count(logical=False),
            'logical_cores': psutil.cpu_count(logical=True),
            'current_freq_mhz': cpu_freq.current if cpu_freq else None,
            'min_freq_mhz': cpu_freq.min if cpu_freq else None,
            'max_freq_mhz': cpu_freq.max if cpu_freq else None,
            'architecture': os.uname().machine,
            'processor': os.uname().processor if hasattr(os.uname(), 'processor') else 'Unknown'
        }
        
        # Get detailed memory info
        memory = psutil.virtual_memory()
        swap = psutil.swap_memory()
        memory_info = {
            'total_gb': round(memory.total / (1024**3), 2),
            'available_gb': round(memory.available / (1024**3), 2),
            'used_gb': round(memory.used / (1024**3), 2),
            'free_gb': round(memory.free / (1024**3), 2),
            'percent': memory.percent,
            'buffers_mb': round(memory.buffers / (1024**2), 2) if hasattr(memory, 'buffers') else 0,
            'cached_mb': round(memory.cached / (1024**2), 2) if hasattr(memory, 'cached') else 0,
            'swap_total_gb': round(swap.total / (1024**3), 2),
            'swap_used_gb': round(swap.used / (1024**3), 2),
            'swap_percent': swap.percent
        }
        
        # Get disk info for all partitions
        disk_info = []
        for part in psutil.disk_partitions():
            try:
                usage = psutil.disk_usage(part.mountpoint)
                disk_info.append({
                    'device': part.device,
                    'mountpoint': part.mountpoint,
                    'fstype': part.fstype,
                    'total_gb': round(usage.total / (1024**3), 2),
                    'used_gb': round(usage.used / (1024**3), 2),
                    'free_gb': round(usage.free / (1024**3), 2),
                    'percent': usage.percent
                })
            except PermissionError:
                pass
        
        # Get running processes (top 10 by memory)
        processes = []
        for proc in sorted(psutil.process_iter(['pid', 'name', 'memory_percent']), 
                          key=lambda p: p.info.get('memory_percent', 0), reverse=True)[:10]:
            try:
                processes.append({
                    'pid': proc.info['pid'],
                    'name': proc.info['name'],
                    'memory_percent': round(proc.info['memory_percent'] or 0, 2)
                })
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                pass
        
        return jsonify({
            'system': {
                'platform': os.uname().sysname,
                'release': os.uname().release,
                'version': os.uname().version,
                'hostname': os.uname().nodename,
                'boot_time': boot_time,
                'uptime_seconds': time.time() - psutil.boot_time()
            },
            'cpu': cpu_info,
            'memory': memory_info,
            'disks': disk_info,
            'top_processes': processes,
            'timestamp': datetime.utcnow().isoformat()
        })
    
    except Exception as e:
        return jsonify({'error': str(e)}), 500

# =============================================================================
# MCP (MODEL CONTEXT PROTOCOL) SERVERS
# =============================================================================
@app.route('/api/mcp/servers', methods=['GET'])
@require_auth
def list_mcp_servers():
    """List all MCP servers"""
    return jsonify({
        'servers': list(mcp_servers.values()),
        'count': len(mcp_servers),
        'connected': sum(1 for s in mcp_servers.values() if s['status'] == 'connected')
    })

@app.route('/api/mcp/servers', methods=['POST'])
@require_auth
def create_mcp_server():
    """Register a new MCP server"""
    data = request.get_json()
    server_id = f"mcp-{str(uuid.uuid4())[:8]}"
    
    server = {
        'id': server_id,
        'name': data.get('name', 'MCP Server'),
        'endpoint': data.get('endpoint', ''),
        'type': data.get('type', 'stdio'),
        'auth_token': data.get('auth_token', ''),
        'status': 'disconnected',
        'capabilities': data.get('capabilities', []),
        'created_at': datetime.utcnow().isoformat(),
        'last_connected': None
    }
    
    mcp_servers[server_id] = server
    
    # Save to DB
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('''
        INSERT INTO mcp_servers (id, name, endpoint, type, auth_token, status, capabilities, created_at)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?)
    ''', (server_id, server['name'], server['endpoint'], server['type'],
          server['auth_token'], 'disconnected', json.dumps(server['capabilities']), server['created_at']))
    conn.commit()
    conn.close()
    
    # Try to connect
    threading.Thread(target=lambda: connect_mcp_server(server_id), daemon=True).start()
    
    return jsonify({'success': True, 'server': server}), 201

def connect_mcp_server(server_id):
    """Attempt to connect to MCP server"""
    server = mcp_servers.get(server_id)
    if not server:
        return
    
    try:
        # Simulate MCP connection
        if server['type'] == 'http':
            response = requests.get(f"{server['endpoint']}/health", 
                                   headers={'Authorization': f"Bearer {server['auth_token']}"},
                                   timeout=10, verify=False)
            if response.status_code == 200:
                server['status'] = 'connected'
                server['last_connected'] = datetime.utcnow().isoformat()
                
                # Try to get capabilities
                try:
                    caps_response = requests.get(f"{server['endpoint']}/capabilities",
                                                headers={'Authorization': f"Bearer {server['auth_token']}"},
                                                timeout=5, verify=False)
                    if caps_response.status_code == 200:
                        server['capabilities'] = caps_response.json().get('capabilities', [])
                except:
                    pass
        else:
            # stdio servers require local execution
            server['status'] = 'connected'
            server['last_connected'] = datetime.utcnow().isoformat()
        
        # Update DB
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        cursor.execute('''
            UPDATE mcp_servers SET status = ?, last_connected = ?, capabilities = ? WHERE id = ?
        ''', (server['status'], server['last_connected'], json.dumps(server['capabilities']), server_id))
        conn.commit()
        conn.close()
        
    except Exception as e:
        server['status'] = 'error'
        server['error'] = str(e)

@app.route('/api/mcp/servers/<server_id>/connect', methods=['POST'])
@require_auth
def mcp_server_connect(server_id):
    """Connect to an MCP server"""
    if server_id not in mcp_servers:
        return jsonify({'error': 'Server not found'}), 404
    
    threading.Thread(target=lambda: connect_mcp_server(server_id), daemon=True).start()
    time.sleep(2)  # Give it time to attempt
    
    return jsonify({'success': True, 'server': mcp_servers[server_id]})

@app.route('/api/mcp/servers/<server_id>', methods=['DELETE'])
@require_auth
def delete_mcp_server(server_id):
    """Remove an MCP server"""
    if server_id in mcp_servers:
        del mcp_servers[server_id]
        
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        cursor.execute('DELETE FROM mcp_servers WHERE id = ?', (server_id,))
        conn.commit()
        conn.close()
    
    return jsonify({'success': True})

@app.route('/api/mcp/servers/<server_id>/invoke', methods=['POST'])
@require_auth
def invoke_mcp_tool(server_id):
    """Invoke a tool on an MCP server"""
    if server_id not in mcp_servers:
        return jsonify({'error': 'Server not found'}), 404
    
    server = mcp_servers[server_id]
    data = request.get_json()
    tool_name = data.get('tool')
    params = data.get('params', {})
    
    if server['status'] != 'connected':
        return jsonify({'error': 'Server not connected'}), 400
    
    try:
        if server['type'] == 'http':
            response = requests.post(
                f"{server['endpoint']}/tools/{tool_name}",
                headers={'Authorization': f"Bearer {server['auth_token']}"},
                json=params,
                timeout=30
            )
            return jsonify(response.json())
        else:
            return jsonify({'error': 'stdio servers not yet supported'}), 400
    except Exception as e:
        return jsonify({'error': str(e)}), 500

# =============================================================================
# CHAT API WITH TOOL SUPPORT & STREAMING
# =============================================================================
@app.route('/api/chat', methods=['POST'])
@require_auth
@limiter.limit("60 per minute")
def chat():
    """Main chat endpoint with tool support"""
    global request_count
    request_count['total'] += 1
    request_count['per_minute'].append(time.time())
    
    data = request.get_json()
    model = data.get('model', 'llama-3.3-70b-versatile')
    messages = data.get('messages', [])
    stream = data.get('stream', False)
    
    # Check for tool usage
    if data.get('tool') == 'web_search' and data.get('tool_url'):
        return handle_tool_chat(messages, model, 'web_search', data['tool_url'])
    
    if data.get('tool') == 'knowledge_base' and data.get('kb_query'):
        return handle_knowledge_chat(messages, model, data['kb_query'])
    
    # Regular chat via router
    try:
        if stream:
            return Response(
                stream_with_context(stream_chat_response(messages, model, data)),
                mimetype='text/event-stream',
                headers={
                    'Cache-Control': 'no-cache',
                    'X-Accel-Buffering': 'no'
                }
            )
        
        response = requests.post(
            f'{ROUTER_URL}/v1/responses',
            headers={'Authorization': f'Bearer {BEARER_TOKEN}'},
            json={
                'model': model,
                'input': messages,
                'temperature': data.get('temperature', 0.7),
                'max_tokens': data.get('max_tokens', 4096)
            },
            timeout=120
        )
        
        router_data = response.json()
        
        if 'response' in router_data:
            # Save to conversation if conversation_id provided
            if data.get('conversation_id'):
                save_message_to_conversation(data['conversation_id'], 
                                            messages[-1]['content'] if messages else '',
                                            router_data['response'])
            
            return jsonify({
                'choices': [{
                    'message': {'role': 'assistant', 'content': router_data['response']},
                    'finish_reason': 'stop'
                }],
                'model': router_data.get('model', model),
                'latency_ms': router_data.get('latency_ms'),
                'usage': router_data.get('usage', {})
            })
        
        return jsonify(router_data), response.status_code
    
    except Exception as e:
        log_system_event('error', 'chat', f'Chat error: {str(e)}')
        return jsonify({'error': str(e)}), 500

def stream_chat_response(messages, model, data):
    """Stream chat response"""
    try:
        response = requests.post(
            f'{ROUTER_URL}/v1/responses',
            headers={'Authorization': f'Bearer {BEARER_TOKEN}'},
            json={
                'model': model,
                'input': messages,
                'temperature': data.get('temperature', 0.7),
                'max_tokens': data.get('max_tokens', 4096),
                'stream': True
            },
            timeout=120,
            stream=True
        )
        
        full_response = []
        
        for line in response.iter_lines():
            if line:
                try:
                    decoded = line.decode('utf-8')
                    if decoded.startswith('data: '):
                        decoded = decoded[6:]
                    
                    chunk = json.loads(decoded)
                    
                    if 'response' in chunk:
                        full_response.append(chunk['response'])
                        yield f"data: {json.dumps({'content': chunk['response']})}\n\n"
                    elif 'done' in chunk and chunk['done']:
                        yield f"data: {json.dumps({'done': True})}\n\n"
                except:
                    pass
        
        # Save complete response
        if data.get('conversation_id') and full_response:
            save_message_to_conversation(data['conversation_id'],
                                        messages[-1]['content'] if messages else '',
                                        ''.join(full_response))
        
        yield f"data: {json.dumps({'done': True})}\n\n"
    
    except Exception as e:
        yield f"data: {json.dumps({'error': str(e)})}\n\n"

def handle_tool_chat(messages, model, tool, tool_input):
    """Handle chat with tool integration"""
    if tool == 'web_search':
        scraped = scrape_website(tool_input)
        
        if 'error' not in scraped:
            context = f"\n\n[WEB SCRAPE RESULT for {scraped['url']}]:\n"
            context += f"Title: {scraped['title']}\n"
            context += f"Description: {scraped['description'][:500]}\n"
            context += f"Headings: {', '.join(scraped.get('headings', []))}\n"
            
            # Add context to messages
            enhanced_messages = messages.copy()
            enhanced_messages.append({'role': 'system', 'content': context})
            
            result = generate_with_ai(
                enhanced_messages[-2]['content'] if len(enhanced_messages) >= 2 else 'Analyze this webpage',
                model
            )
            
            if result['success']:
                return jsonify({
                    'choices': [{
                        'message': {'role': 'assistant', 'content': result['content']},
                        'finish_reason': 'stop'
                    }],
                    'model': result['model'],
                    'tool_used': 'web_search',
                    'scraped_url': scraped['url'],
                    'latency_ms': result['latency_ms']
                })
        
        return jsonify({'error': f'Failed to scrape: {scraped.get("error")}'}), 500
    
    return jsonify({'error': 'Unknown tool'}), 400

def handle_knowledge_chat(messages, model, query):
    """Handle chat with knowledge base query"""
    # Search knowledge base
    results = []
    for entry in knowledge_base.values():
        score = 0
        query_words = query.lower().split()
        for word in query_words:
            if word in entry['content'].lower():
                score += 1
        if score > 0:
            results.append(entry)
    
    results.sort(key=lambda x: len(x['content']), reverse=True)
    
    context = ""
    if results:
        context = "\n\n[KNOWLEDGE BASE CONTEXT]:\n"
        for entry in results[:3]:
            context += f"\n--- {entry['title']} ---\n{entry['content'][:800]}\n"
    
    enhanced_messages = messages.copy()
    if context:
        enhanced_messages.append({'role': 'system', 'content': context})
    
    result = generate_with_ai(
        enhanced_messages[-1]['content'] if enhanced_messages else query,
        model
    )
    
    if result['success']:
        return jsonify({
            'choices': [{
                'message': {'role': 'assistant', 'content': result['content']},
                'finish_reason': 'stop'
            }],
            'model': result['model'],
            'tool_used': 'knowledge_base',
            'kb_entries_found': len(results),
            'latency_ms': result['latency_ms']
        })
    
    return jsonify({'error': result['error']}), 500

# =============================================================================
# CONVERSATIONS API
# =============================================================================
def save_message_to_conversation(conv_id, user_msg, assistant_msg):
    """Save messages to conversation"""
    if conv_id not in conversations_db:
        conversations_db[conv_id] = {
            'id': conv_id,
            'title': user_msg[:50] + '...' if len(user_msg) > 50 else user_msg,
            'messages': [],
            'created_at': datetime.utcnow().isoformat(),
            'updated_at': datetime.utcnow().isoformat()
        }
    
    conversations_db[conv_id]['messages'].append({
        'role': 'user',
        'content': user_msg,
        'timestamp': datetime.utcnow().isoformat()
    })
    conversations_db[conv_id]['messages'].append({
        'role': 'assistant',
        'content': assistant_msg,
        'timestamp': datetime.utcnow().isoformat()
    })
    conversations_db[conv_id]['updated_at'] = datetime.utcnow().isoformat()
    
    # Save to DB
    try:
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        cursor.execute('''
            INSERT OR REPLACE INTO conversations (id, title, created_at, updated_at, messages)
            VALUES (?, ?, ?, ?, ?)
        ''', (conv_id, conversations_db[conv_id]['title'],
              conversations_db[conv_id]['created_at'],
              conversations_db[conv_id]['updated_at'],
              json.dumps(conversations_db[conv_id]['messages'])))
        conn.commit()
        conn.close()
    except:
        pass

@app.route('/api/conversations', methods=['GET'])
@require_auth
def list_conversations():
    """List all conversations"""
    # Load from DB if empty
    if not conversations_db:
        try:
            conn = sqlite3.connect(DB_PATH)
            cursor = conn.cursor()
            cursor.execute('SELECT * FROM conversations ORDER BY updated_at DESC')
            for row in cursor.fetchall():
                conversations_db[row[0]] = {
                    'id': row[0],
                    'title': row[1],
                    'created_at': row[2],
                    'updated_at': row[3],
                    'messages': json.loads(row[4]) if row[4] else []
                }
            conn.close()
        except:
            pass
    
    convs = sorted(conversations_db.values(), key=lambda x: x['updated_at'], reverse=True)
    return jsonify({'conversations': convs, 'count': len(convs)})

@app.route('/api/conversations', methods=['POST'])
@require_auth
def create_conversation():
    """Create a new conversation"""
    data = request.get_json()
    conv_id = f"conv-{str(uuid.uuid4())[:8]}"
    
    conversation = {
        'id': conv_id,
        'title': data.get('title', 'New Conversation'),
        'model': data.get('model', 'llama-3.3-70b-versatile'),
        'messages': [],
        'created_at': datetime.utcnow().isoformat(),
        'updated_at': datetime.utcnow().isoformat()
    }
    
    conversations_db[conv_id] = conversation
    
    # Save to DB
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('''
        INSERT INTO conversations (id, title, created_at, updated_at, messages)
        VALUES (?, ?, ?, ?, ?)
    ''', (conv_id, conversation['title'], conversation['created_at'],
          conversation['updated_at'], '[]'))
    conn.commit()
    conn.close()
    
    return jsonify({'success': True, 'conversation': conversation}), 201

@app.route('/api/conversations/<conv_id>', methods=['GET'])
@require_auth
def get_conversation(conv_id):
    """Get conversation with messages"""
    if conv_id not in conversations_db:
        # Try to load from DB
        try:
            conn = sqlite3.connect(DB_PATH)
            cursor = conn.cursor()
            cursor.execute('SELECT * FROM conversations WHERE id = ?', (conv_id,))
            row = cursor.fetchone()
            if row:
                conversations_db[conv_id] = {
                    'id': row[0],
                    'title': row[1],
                    'created_at': row[2],
                    'updated_at': row[3],
                    'messages': json.loads(row[4]) if row[4] else []
                }
            conn.close()
        except:
            pass
    
    if conv_id not in conversations_db:
        return jsonify({'error': 'Conversation not found'}), 404
    
    return jsonify(conversations_db[conv_id])

@app.route('/api/conversations/<conv_id>', methods=['DELETE'])
@require_auth
def delete_conversation(conv_id):
    """Delete a conversation"""
    if conv_id in conversations_db:
        del conversations_db[conv_id]
        
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        cursor.execute('DELETE FROM conversations WHERE id = ?', (conv_id,))
        conn.commit()
        conn.close()
    
    return jsonify({'success': True})

# =============================================================================
# FILE UPLOADS
# =============================================================================
@app.route('/api/files', methods=['GET'])
@require_auth
def list_files():
    """List uploaded files"""
    return jsonify({'files': list(file_uploads.values()), 'count': len(file_uploads)})

@app.route('/api/files/upload', methods=['POST'])
@require_auth
def upload_file():
    """Upload a file for analysis"""
    if 'file' not in request.files:
        return jsonify({'error': 'No file provided'}), 400
    
    file = request.files['file']
    if file.filename == '':
        return jsonify({'error': 'No file selected'}), 400
    
    file_id = f"file-{str(uuid.uuid4())[:8]}"
    filename = secure_filename(file.filename)
    
    # Save file
    file_path = os.path.join(UPLOADS_DIR, f"{file_id}_{filename}")
    file.save(file_path)
    
    # Read content for preview
    file.seek(0)
    file_content = file.read()
    content_hash = hashlib.sha256(file_content).hexdigest()[:16]
    
    # Generate preview for text files
    content_preview = ''
    if file.content_type and (file.content_type.startswith('text/') or 
                              filename.endswith(('.py', '.js', '.json', '.md', '.txt', '.yaml', '.yml', '.html', '.css'))):
        try:
            content_preview = file_content[:5000].decode('utf-8', errors='ignore')
        except:
            pass
    
    file_info = {
        'id': file_id,
        'name': filename,
        'size': len(file_content),
        'type': file.content_type or 'application/octet-stream',
        'uploaded_at': datetime.utcnow().isoformat(),
        'status': 'ready',
        'content_hash': content_hash,
        'content_preview': content_preview,
        'file_path': file_path
    }
    
    file_uploads[file_id] = file_info
    
    # Save to DB
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('''
        INSERT INTO file_uploads (id, name, size, type, uploaded_at, status, content_hash, file_path)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?)
    ''', (file_id, filename, len(file_content), file_info['type'],
          file_info['uploaded_at'], 'ready', content_hash, file_path))
    conn.commit()
    conn.close()
    
    log_system_event('info', 'files', f"File uploaded: {filename}", 
                    {'file_id': file_id, 'size': len(file_content)})
    
    return jsonify({'success': True, 'file': file_info}), 201

@app.route('/api/files/<file_id>', methods=['GET'])
@require_auth
def get_file(file_id):
    """Get file info"""
    if file_id not in file_uploads:
        return jsonify({'error': 'File not found'}), 404
    return jsonify(file_uploads[file_id])

@app.route('/api/files/<file_id>/download', methods=['GET'])
@require_auth
def download_file(file_id):
    """Download uploaded file"""
    if file_id not in file_uploads:
        return jsonify({'error': 'File not found'}), 404
    
    file_info = file_uploads[file_id]
    return send_from_directory(UPLOADS_DIR, os.path.basename(file_info['file_path']),
                               as_attachment=True, download_name=file_info['name'])

@app.route('/api/files/<file_id>', methods=['DELETE'])
@require_auth
def delete_file(file_id):
    """Delete uploaded file"""
    if file_id in file_uploads:
        file_info = file_uploads[file_id]
        
        # Delete physical file
        try:
            if os.path.exists(file_info['file_path']):
                os.remove(file_info['file_path'])
        except:
            pass
        
        del file_uploads[file_id]
        
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        cursor.execute('DELETE FROM file_uploads WHERE id = ?', (file_id,))
        conn.commit()
        conn.close()
    
    return jsonify({'success': True})

# =============================================================================
# INFERENCE OUTLET (PRODUCTION API)
# =============================================================================
@app.route('/api/inference', methods=['POST'])
@require_auth
@limiter.limit("1000 per hour")
def inference():
    """Production inference endpoint"""
    data = request.get_json()
    
    # Validate required fields
    if 'prompt' not in data:
        return jsonify({'error': 'prompt is required'}), 400
    
    model = data.get('model', 'llama-3.3-70b-versatile')
    prompt = data['prompt']
    
    # Build messages
    messages = [{'role': 'user', 'content': prompt}]
    
    if data.get('system'):
        messages.insert(0, {'role': 'system', 'content': data['system']})
    
    # Call router
    try:
        response = requests.post(
            f'{ROUTER_URL}/v1/responses',
            headers={'Authorization': f'Bearer {BEARER_TOKEN}'},
            json={
                'model': model,
                'input': messages,
                'temperature': data.get('temperature', 0.7),
                'max_tokens': data.get('max_tokens', 4096)
            },
            timeout=120
        )
        
        router_data = response.json()
        
        if 'response' in router_data:
            return jsonify({
                'success': True,
                'output': router_data['response'],
                'model': router_data.get('model', model),
                'latency_ms': router_data.get('latency_ms'),
                'usage': router_data.get('usage', {}),
                'timestamp': datetime.utcnow().isoformat()
            })
        else:
            return jsonify({'error': router_data.get('error', 'Unknown error')}), 500
    
    except Exception as e:
        return jsonify({'error': str(e)}), 500

@app.route('/api/inference/batch', methods=['POST'])
@require_auth
def batch_inference():
    """Batch inference for multiple prompts"""
    data = request.get_json()
    prompts = data.get('prompts', [])
    model = data.get('model', 'llama-3.3-70b-versatile')
    
    if not prompts:
        return jsonify({'error': 'prompts array is required'}), 400
    
    results = []
    for prompt in prompts:
        try:
            result = generate_with_ai(prompt, model)
            results.append({
                'prompt': prompt[:100],
                'output': result['content'] if result['success'] else None,
                'error': None if result['success'] else result['error'],
                'latency_ms': result.get('latency_ms')
            })
        except Exception as e:
            results.append({
                'prompt': prompt[:100],
                'output': None,
                'error': str(e)
            })
    
    return jsonify({
        'success': True,
        'results': results,
        'total': len(results),
        'successful': sum(1 for r in results if r['error'] is None),
        'timestamp': datetime.utcnow().isoformat()
    })

# =============================================================================
# METRICS & MONITORING
# =============================================================================
@app.route('/api/metrics', methods=['GET'])
@require_auth
def get_metrics():
    """Get Prometheus-compatible metrics"""
    output = []
    
    # System metrics
    cpu = psutil.cpu_percent()
    memory = psutil.virtual_memory()
    
    output.append(f'# HELP nexus_cpu_percent CPU usage percent')
    output.append(f'# TYPE nexus_cpu_percent gauge')
    output.append(f'nexus_cpu_percent {cpu}')
    
    output.append(f'# HELP nexus_memory_percent Memory usage percent')
    output.append(f'# TYPE nexus_memory_percent gauge')
    output.append(f'nexus_memory_percent {memory.percent}')
    
    output.append(f'# HELP nexus_agents_total Total number of agents')
    output.append(f'# TYPE nexus_agents_total gauge')
    output.append(f'nexus_agents_total {len(agents_db)}')
    
    output.append(f'# HELP nexus_agents_active Active agents')
    output.append(f'# TYPE nexus_agents_active gauge')
    output.append(f'nexus_agents_active {sum(1 for a in agents_db.values() if a["status"] == "active")}')
    
    output.append(f'# HELP nexus_training_jobs_total Total training jobs')
    output.append(f'# TYPE nexus_training_jobs_total gauge')
    output.append(f'nexus_training_jobs_total {len(training_jobs)}')
    
    output.append(f'# HELP nexus_requests_total Total API requests')
    output.append(f'# TYPE nexus_requests_total counter')
    output.append(f'nexus_requests_total {request_count["total"]}')
    
    return Response('\n'.join(output), mimetype='text/plain')

