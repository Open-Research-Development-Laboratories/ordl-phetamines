    })

@app.route('/api/agents', methods=['POST'])
@require_auth
def create_agent():
    """Create a new agent with full audit logging"""
    data = request.get_json()
    agent_id = str(uuid.uuid4())[:8]
    agent = {
        'id': agent_id,
        'name': data.get('name', f'AGENT-{agent_id.upper()}'),
        'persona': data.get('persona', 'General Purpose'),
        'model': data.get('model', 'llama-3.3-70b-versatile'),
        'clearance': data.get('clearance', 'SECRET'),
        'status': 'active',
        'created_at': datetime.utcnow().isoformat(),
        'tasks_completed': 0,
        'capabilities': data.get('capabilities', []),
        'description': data.get('description', 'AI agent ready for tasks.'),
        'config': data.get('config', {})
    }
    
    # Save to memory and DB
    agents_db[agent_id] = agent
    agent_audit_logs[agent_id] = []
    
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('''
        INSERT INTO agents (id, name, persona, model, clearance, status, 
            created_at, tasks_completed, capabilities, description, config)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    ''', (agent['id'], agent['name'], agent['persona'], agent['model'], 
          agent['clearance'], agent['status'], agent['created_at'],
          agent['tasks_completed'], json.dumps(agent['capabilities']), 
          agent['description'], json.dumps(agent['config'])))
    
    # Log creation
    cursor.execute('''
        INSERT INTO agent_audit_logs (agent_id, timestamp, action, details)
        VALUES (?, ?, ?, ?)
    ''', (agent_id, datetime.utcnow().isoformat(), 'CREATED',
          f"Agent {agent['name']} deployed with {agent['persona']} persona"))
    
    conn.commit()
    conn.close()
    
    log_system_event('info', 'agents', f'Agent {agent["name"]} created', {'agent_id': agent_id})
    
    return jsonify({'success': True, 'agent': agent}), 201

@app.route('/api/agents/<agent_id>', methods=['GET'])
@require_auth
def get_agent(agent_id):
    """Get agent details with full statistics"""
    if agent_id not in agents_db:
        return jsonify({'error': 'Agent not found'}), 404
    
    agent = agents_db[agent_id].copy()
    agent['audit_log_count'] = len(agent_audit_logs.get(agent_id, []))
    agent['recent_logs'] = agent_audit_logs.get(agent_id, [])[:10]
    
    return jsonify(agent)

@app.route('/api/agents/<agent_id>/logs', methods=['GET'])
@require_auth
def get_agent_logs(agent_id):
    """Get comprehensive agent audit logs"""
    if agent_id not in agents_db:
        return jsonify({'error': 'Agent not found'}), 404
    
    limit = request.args.get('limit', 100, type=int)
    action_filter = request.args.get('action', None)
    
    logs = agent_audit_logs.get(agent_id, [])
    
    if action_filter:
        logs = [log for log in logs if log['action'] == action_filter.upper()]
    
    # Paginate
    offset = request.args.get('offset', 0, type=int)
    total = len(logs)
    logs = logs[offset:offset+limit]
    
    return jsonify({
        'agent': agents_db[agent_id],
        'logs': logs,
        'total': total,
        'offset': offset,
        'limit': limit
    })

@app.route('/api/agents/<agent_id>', methods=['DELETE'])
@require_auth
def delete_agent(agent_id):
    """Terminate an agent with audit logging"""
    if agent_id not in agents_db:
        return jsonify({'error': 'Agent not found'}), 404
    
    agent_name = agents_db[agent_id]['name']
    
    # Log termination
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('''
        INSERT INTO agent_audit_logs (agent_id, timestamp, action, details)
        VALUES (?, ?, ?, ?)
    ''', (agent_id, datetime.utcnow().isoformat(), 'TERMINATED',
          f"Agent {agent_name} terminated by operator"))
    
    # Mark as deleted in DB
    cursor.execute('DELETE FROM agents WHERE id = ?', (agent_id,))
    
    conn.commit()
    conn.close()
    
    del agents_db[agent_id]
    if agent_id in agent_audit_logs:
        del agent_audit_logs[agent_id]
    
    log_system_event('warning', 'agents', f'Agent {agent_name} terminated', {'agent_id': agent_id})
    
    return jsonify({'success': True, 'message': 'Agent terminated'})

@app.route('/api/agents/<agent_id>/control', methods=['POST'])
@require_auth
def control_agent(agent_id):
    """Control agent state (activate/deactivate/pause/resume)"""
    if agent_id not in agents_db:
        return jsonify({'error': 'Agent not found'}), 404
    
    data = request.get_json()
    action = data.get('action')
    
    valid_actions = ['activate', 'deactivate', 'pause', 'resume']
    if action not in valid_actions:
        return jsonify({'error': f'Invalid action. Use: {valid_actions}'}), 400
    
    old_status = agents_db[agent_id]['status']
    
    if action == 'activate':
        agents_db[agent_id]['status'] = 'active'
    elif action == 'deactivate':
        agents_db[agent_id]['status'] = 'idle'
    elif action == 'pause':
        agents_db[agent_id]['status'] = 'paused'
    elif action == 'resume':
        agents_db[agent_id]['status'] = 'active'
    
    new_status = agents_db[agent_id]['status']
    
    # Update DB and log
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('UPDATE agents SET status = ? WHERE id = ?', (new_status, agent_id))
    cursor.execute('''
        INSERT INTO agent_audit_logs (agent_id, timestamp, action, details)
        VALUES (?, ?, ?, ?)
    ''', (agent_id, datetime.utcnow().isoformat(), action.upper(),
          f"Status: {old_status} -> {new_status}"))
    conn.commit()
    conn.close()
    
    # Add to in-memory log
    if agent_id not in agent_audit_logs:
        agent_audit_logs[agent_id] = []
    agent_audit_logs[agent_id].insert(0, {
        'timestamp': datetime.utcnow().isoformat(),
        'action': action.upper(),
        'details': f"Status: {old_status} -> {new_status}"
    })
    
    return jsonify({'success': True, 'agent': agents_db[agent_id]})

@app.route('/api/agents/<agent_id>/assign', methods=['POST'])
@require_auth
def assign_task_to_agent(agent_id):
    """Assign a specific task to an agent"""
    if agent_id not in agents_db:
        return jsonify({'error': 'Agent not found'}), 404
    
    data = request.get_json()
    task_type = data.get('type', 'generic')
    task_description = data.get('description', '')
    
    agent = agents_db[agent_id]
    
    # Generate response based on agent's persona
    system_prompt = f"You are {agent['name']}, a {agent['persona']}. {agent.get('description', '')}"
    
    result = generate_with_ai(task_description, agent['model'], system_prompt)
    
    if result['success']:
        agent['tasks_completed'] += 1
        
        # Update DB
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        cursor.execute('UPDATE agents SET tasks_completed = ? WHERE id = ?', 
                      (agent['tasks_completed'], agent_id))
        cursor.execute('''
            INSERT INTO agent_audit_logs (agent_id, timestamp, action, details)
            VALUES (?, ?, ?, ?)
        ''', (agent_id, datetime.utcnow().isoformat(), 'TASK_COMPLETED',
              f"{task_type}: {task_description[:100]}..."))
        conn.commit()
        conn.close()
        
        # Update in-memory
        if agent_id not in agent_audit_logs:
            agent_audit_logs[agent_id] = []
        agent_audit_logs[agent_id].insert(0, {
            'timestamp': datetime.utcnow().isoformat(),
            'action': 'TASK_COMPLETED',
            'details': f"{task_type}: {task_description[:100]}..."
        })
        
        return jsonify({
            'success': True,
            'result': result['content'],
            'model_used': result['model'],
            'latency_ms': result['latency_ms'],
            'tasks_completed': agent['tasks_completed']
        })
    else:
        return jsonify({'success': False, 'error': result['error']}), 500

