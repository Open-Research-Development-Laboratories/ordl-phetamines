# =============================================================================
# CORE ENDPOINTS
# =============================================================================

async def ollama_generate(
    request_id: str,
    model: str,
    prompt: str,
    stream: bool,
    options: Dict[str, Any],
) -> Response:
    """Generate via Ollama with full streaming support."""
    http = await get_http()
    url = f"{CFG.ollama_base}/api/generate"
    
    body = {
        "model": model,
        "prompt": prompt,
        "stream": stream,
        "options": options,
    }
    
    log.info(f"[{request_id}] -> ollama model={model} stream={stream}")
    t0 = time.time()
    
    try:
        if stream:
            req = http.build_request("POST", url, json=body)
            upstream = await http.send(req, stream=True)
            
            async def gen():
                try:
                    async for chunk in upstream.aiter_bytes():
                        yield chunk
                except asyncio.CancelledError:
                    raise
                except Exception as e:
                    log.error(f"[{request_id}] Stream error: {e}")
                finally:
                    await upstream.aclose()
                    log.info(f"[{request_id}] <- stream done in {time.time()-t0:.2f}s")
            
            return StreamingResponse(
                gen(),
                status_code=upstream.status_code,
                media_type="application/x-ndjson",
            )
        else:
            r = await http.post(url, json=body)
            log.info(f"[{request_id}] <- done in {time.time()-t0:.2f}s")
            return JSONResponse(content=r.json(), status_code=r.status_code)
    
    except httpx.TimeoutException:
        raise HTTPException(status_code=504, detail="Upstream timeout")
    except Exception as e:
        log.error(f"[{request_id}] Ollama error: {e}")
        raise HTTPException(status_code=502, detail="Upstream error")


async def swarm_generate(
    request_id: str,
    task_type: str,
    prompt: str,
    context: Dict[str, Any],
    stream: bool,
) -> Response:
    """Generate using the multi-agent swarm."""
    if not CFG.swarm_enabled or not SWARM_AVAILABLE:
        raise HTTPException(status_code=503, detail="Swarm not available")
    
    log.info(f"[{request_id}] -> SWARM task={task_type}")
    t0 = time.time()
    
    try:
        result = await process_task(
            task_type=task_type,
            prompt=prompt,
            context=context,
            request_id=request_id,
        )
        
        output = result["output"]
        confidence = result["confidence"]
        iterations = result["iterations"]
        
        log.info(f"[{request_id}] <- SWARM done confidence={confidence:.2f} iters={iterations} time={time.time()-t0:.2f}s")
        
        if stream:
            # Simulate streaming for swarm output
            async def stream_gen():
                # Send output in chunks to simulate generation
                chunk_size = 50
                for i in range(0, len(output), chunk_size):
                    chunk = output[i:i+chunk_size]
                    data = {
                        "response": chunk,
                        "done": False,
                        "model": "swarm-consensus",
                    }
                    yield json.dumps(data).encode() + b"\n"
                    await asyncio.sleep(0.01)  # Small delay for effect
                
                # Final chunk
                yield json.dumps({
                    "response": "",
                    "done": True,
                    "done_reason": "stop",
                    "model": "swarm-consensus",
                    "confidence": confidence,
                    "iterations": iterations,
                }).encode() + b"\n"
            
            return StreamingResponse(stream_gen(), media_type="application/x-ndjson")
        else:
            return JSONResponse(content={
                "response": output,
                "done": True,
                "model": "swarm-consensus",
                "confidence": confidence,
                "iterations": iterations,
                "provenance": result.get("provenance", {}),
            })
    
    except Exception as e:
        log.error(f"[{request_id}] Swarm error: {e}")
        raise HTTPException(status_code=500, detail=f"Swarm error: {str(e)}")


async def cloud_generate(
    request_id: str,
    prompt: str,
    payload: Dict[str, Any],
    stream: bool,
) -> Response:
    """Generate using cloud provider with automatic fallback."""
    if not CLOUD_AVAILABLE:
        raise HTTPException(status_code=503, detail="Cloud routing not available")
    
    router = get_router()
    
    # Extract parameters
    max_tokens = payload.get("max_tokens") or payload.get("max_output_tokens") or 1024
    temperature = payload.get("temperature", 0.2)
    prefer_local = payload.get("_local", False)
    
    log.info(f"[{request_id}] -> cloud routing")
    t0 = time.time()
    
    try:
        result = await router.generate(
            prompt=prompt,
            max_tokens=max_tokens,
            temperature=temperature,
            prefer_local=prefer_local,
        )
        
        elapsed = time.time() - t0
        log.info(f"[{request_id}] <- cloud done | provider={result.provider.value} | model={result.model} | latency={result.latency_ms:.0f}ms | total={elapsed:.2f}s")
        
        if not result.success:
            log.error(f"[{request_id}] Cloud generation failed: {result.error}")
            raise HTTPException(status_code=502, detail=f"Generation failed: {result.error}")
        
        if stream:
            # Simulate streaming
            async def stream_gen():
                chunk_size = 50
                for i in range(0, len(result.output), chunk_size):
                    chunk = result.output[i:i+chunk_size]
                    data = {
                        "response": chunk,
                        "done": False,
                        "model": f"{result.provider.value}/{result.model}",
                    }
                    yield json.dumps(data).encode() + b"\n"
                    await asyncio.sleep(0.01)
                
                yield json.dumps({
                    "response": "",
                    "done": True,
                    "done_reason": "stop",
                    "model": f"{result.provider.value}/{result.model}",
                    "total_duration": int(result.latency_ms * 1_000_000),
                }).encode() + b"\n"
            
            return StreamingResponse(stream_gen(), media_type="application/x-ndjson")
        else:
            return JSONResponse(content={
                "response": result.output,
                "done": True,
                "model": f"{result.provider.value}/{result.model}",
                "total_duration": int(result.latency_ms * 1_000_000),
                "provider": result.provider.value,
                "latency_ms": result.latency_ms,
            })
    
    except HTTPException:
        raise
    except Exception as e:
        log.error(f"[{request_id}] Cloud error: {e}")
        raise HTTPException(status_code=500, detail=f"Cloud routing error: {str(e)}")


@app.post("/v1/responses")
@app.post("/v1/chat/completions")
@app.post("/v1/completions")
@app.post("/v1/engines/copilot-codex/completions")
async def handle_request(
    request: Request,
    authorization: Optional[str] = Header(default=None),
):
    """Main request handler - routes to single model or swarm."""
    require_bearer(authorization)
    
    request_id = getattr(request.state, "request_id", str(uuid.uuid4()))
    t0 = getattr(request.state, "t0", time.time())
    
    # Read and validate body
    try:
        body = await request.body()
        if len(body) > CFG.max_request_bytes:
            raise HTTPException(status_code=413, detail="Request too large")
        payload = json.loads(body)
    except json.JSONDecodeError:
        raise HTTPException(status_code=400, detail="Invalid JSON")
    
    # Extract prompt
    prompt, format_type = normalize_prompt(payload)
    if not prompt:
        raise HTTPException(status_code=400, detail="No prompt provided")
    
    # Sanitize
    if CFG.enable_prompt_sanitization:
        prompt, is_safe = _sanitizer.sanitize(prompt)
        if not is_safe:
            log.warning(f"[{request_id}] Injection attempt blocked")
            raise HTTPException(status_code=400, detail="Prompt failed security check")
    
    if len(prompt) > CFG.max_prompt_chars:
        raise HTTPException(status_code=413, detail="Prompt too long")
    
    stream = bool(payload.get("stream", False))
    
    # Determine routing strategy
    use_swarm = CFG.swarm_enabled and SWARM_AVAILABLE
    force_swarm = payload.get("_swarm", False)
    use_cloud = payload.get("_cloud", True) and CLOUD_AVAILABLE  # Default to cloud
    force_local = payload.get("_local", False)
    
    # Cloud routing takes precedence over local (unless forced)
    if use_cloud and CLOUD_AVAILABLE and not force_local and not force_swarm:
        log.info(f"[{request_id}] Using cloud routing")
        return await cloud_generate(
            request_id=request_id,
            prompt=prompt,
            payload=payload,
            stream=stream,
        )
    
    if use_swarm or force_swarm:
        # Use multi-agent swarm
        task_type = detect_task_type(prompt)
        context = extract_code_context(prompt)
        context["original_format"] = format_type
        context["model_hint"] = choose_model(prompt)
        
        return await swarm_generate(
            request_id=request_id,
            task_type=task_type,
            prompt=prompt,
            context=context,
            stream=stream,
        )
    else:
        # Use single model routing
        model = choose_model(prompt)
        
        # Map options
        options = {}
        if "max_tokens" in payload or "max_output_tokens" in payload:
            options["num_predict"] = payload.get("max_tokens") or payload.get("max_output_tokens")
        if "temperature" in payload:
            options["temperature"] = payload["temperature"]
        if "top_p" in payload:
            options["top_p"] = payload["top_p"]
        
        return await ollama_generate(
            request_id=request_id,
            model=model,
            prompt=prompt,
            stream=stream,
            options=options,
        )


# =============================================================================
# IDE API ENDPOINTS (for CLI compatibility)
# =============================================================================

@app.get("/api/models")
async def api_list_models(authorization: Optional[str] = Header(default=None)):
    """List available models with specifications."""
    require_bearer(authorization)
    
    from model_config import CLOUD_MODELS, LOCAL_MODELS
    
    models = []
    for model_id, spec in {**CLOUD_MODELS, **LOCAL_MODELS}.items():
        models.append({
            "id": model_id,
            "provider": spec.provider,
            "tier": spec.tier.name,
            "context_window": spec.context_window,
            "strengths": spec.strengths,
            "latency_profile": spec.latency_profile,
            "best_for": [c.value for c in spec.best_for],
        })
    
    return {"models": models}


class GenerateRequest(BaseModel):
    prompt: str
    language: str = "python"
    model: Optional[str] = None


@app.post("/api/generate")
async def api_generate(request: GenerateRequest, authorization: Optional[str] = Header(default=None)):
    """Generate code with optimal model selection."""
    require_bearer(authorization)
    
    request_id = str(uuid.uuid4())
    
    # Build full prompt
    full_prompt = f"Language: {request.language}\n\nTask: {request.prompt}\n\nGenerate production-ready code with comments and error handling."
    
    # Generate using cloud router
    if CLOUD_AVAILABLE:
        router = get_router()
        result = await router.generate(
            prompt=full_prompt,
            max_tokens=2048,
            temperature=0.2,
        )
        
        if not result.success:
            raise HTTPException(status_code=500, detail=result.error)
        
        return {
            "code": result.output,
            "language": request.language,
            "model_used": result.model,
            "provider": result.provider.value,
            "latency_ms": result.latency_ms,
        }
    else:
        raise HTTPException(status_code=503, detail="Cloud routing not available")


class ChatRequest(BaseModel):
    message: str


@app.post("/api/chat")
async def api_chat(request: ChatRequest, authorization: Optional[str] = Header(default=None)):
    """Chat with AI assistant."""
    require_bearer(authorization)
    
    system_msg = "You are an expert software engineer and coding assistant. Provide concise, practical help."
    
    if CLOUD_AVAILABLE:
        router = get_router()
        result = await router.generate(
            prompt=request.message,
            system_prompt=system_msg,
            max_tokens=1024,
            temperature=0.7,
        )
        
        return {
            "response": result.output,
            "model": result.model,
            "provider": result.provider.value,
        }
    else:
        raise HTTPException(status_code=503, detail="Cloud routing not available")


# =============================================================================
# ENTRY POINT
# =============================================================================

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(
        app,
        host=CFG.router_bind,
        port=CFG.router_port,
        log_level="info",
        access_log=False,
    )
