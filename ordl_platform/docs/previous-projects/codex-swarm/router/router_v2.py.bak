        router = get_router()
        log.info("NEXUS online | bind=%s:%s | cloud=%s | groq=%s", 
                 CFG.router_bind, CFG.router_port, 
                 CLOUD_AVAILABLE, router.groq.is_available())
    else:
        log.info("NEXUS online | bind=%s:%s | cloud=disabled", 
                 CFG.router_bind, CFG.router_port)


@app.on_event("shutdown")
async def shutdown():
    global _http
    if _http:
        await _http.aclose()
        _http = None


@app.middleware("http")
async def security_middleware(request: Request, call_next):
    """Apply security controls to all requests."""
    ip = client_ip(request)
    request_id = request.headers.get("x-request-id") or str(uuid.uuid4())
    request.state.request_id = request_id
    request.state.t0 = time.time()
    
    # CIDR check
    if not cidr_allowed(ip):
        log.warning(f"[{request_id}] CIDR block: {ip}")
        return JSONResponse(status_code=403, content={"error": "forbidden"})
    
    # Rate limiting
    if not await rate_limit_allow(ip):
        log.warning(f"[{request_id}] Rate limit: {ip}")
        return JSONResponse(status_code=429, content={"error": "rate_limited"})
    
    resp = await call_next(request)
    resp.headers["x-request-id"] = request_id
    return resp


