@dataclass(frozen=True)
class Config:
    router_bind: str
    router_port: int
    ollama_base: str
    
    # Model configuration
    model_arch: str
    model_impl: str
    model_review: str
    
    # Security
    require_bearer_token: Optional[str]
    allow_cidrs: List[ipaddress._BaseNetwork]
    trusted_proxy_cidrs: List[ipaddress._BaseNetwork]
    
    # Limits
    max_request_bytes: int
    max_prompt_chars: int
    rate_limit_rps: float
    rate_limit_burst: int
    router_timeout_s: float
    
    # Swarm mode
    swarm_enabled: bool
    swarm_consensus_threshold: float
    
    # Advanced features
    enable_audit_log: bool
    enable_prompt_sanitization: bool


def _env(name: str, default: Optional[str] = None) -> str:
    v = os.getenv(name, default)
    if v is None:
        raise RuntimeError(f"Missing required env var: {name}")
    return v


def _parse_cidrs(csv: str) -> List[ipaddress._BaseNetwork]:
    out: List[ipaddress._BaseNetwork] = []
    for part in (csv or "").split(","):
        p = part.strip()
        if p:
            out.append(ipaddress.ip_network(p, strict=False))
    return out


def load_config() -> Config:
    return Config(
        router_bind=_env("ROUTER_BIND", "127.0.0.1"),
        router_port=int(_env("ROUTER_PORT", "18000")),
        ollama_base=_env("OLLAMA_BASE", "http://127.0.0.1:11434").rstrip("/"),
        
        model_arch=_env("MODEL_ARCH", "qwen2.5:72b-instruct-q4_K_M"),
        model_impl=_env("MODEL_IMPL", "qwen2.5-coder:32b"),
        model_review=_env("MODEL_REVIEW", "qwen2.5-coder:14b"),
        
        require_bearer_token=os.getenv("ROUTER_BEARER_TOKEN", "").strip() or None,
        allow_cidrs=_parse_cidrs(os.getenv("ALLOW_CIDRS", "")),
        trusted_proxy_cidrs=_parse_cidrs(os.getenv("TRUSTED_PROXY_CIDRS", "")),
        
        max_request_bytes=int(_env("MAX_REQUEST_BYTES", str(256 * 1024))),
        max_prompt_chars=int(_env("MAX_PROMPT_CHARS", "256000")),
        rate_limit_rps=float(_env("RATE_LIMIT_RPS", "10")),
        rate_limit_burst=int(_env("RATE_LIMIT_BURST", "20")),
        router_timeout_s=float(_env("ROUTER_TIMEOUT_S", "1800")),
        
        swarm_enabled=os.getenv("SWARM_ENABLED", "true").lower() == "true" and SWARM_AVAILABLE,
        swarm_consensus_threshold=float(_env("SWARM_THRESHOLD", "0.8")),
        
        enable_audit_log=os.getenv("ENABLE_AUDIT_LOG", "true").lower() == "true",
        enable_prompt_sanitization=os.getenv("ENABLE_SANITIZATION", "true").lower() == "true",
    )


CFG = load_config()
log.info(f"NEXUS initialized | swarm={CFG.swarm_enabled} | models={CFG.model_arch},{CFG.model_impl},{CFG.model_review}")


# =============================================================================
# SECURITY COMPONENTS
# =============================================================================

class TokenBucket:
    __slots__ = ("capacity", "rate", "tokens", "ts")
    def __init__(self, capacity: int, rate: float):
        self.capacity = float(capacity)
        self.rate = float(rate)
        self.tokens = float(capacity)
        self.ts = time.monotonic()
    
    def allow(self, cost: float = 1.0) -> bool:
        now = time.monotonic()
        self.tokens = min(self.capacity, self.tokens + (now - self.ts) * self.rate)
        self.ts = now
        if self.tokens >= cost:
            self.tokens -= cost
            return True
        return False


_rate_lock = asyncio.Lock()
_rate_state: Dict[str, TokenBucket] = {}


async def rate_limit_allow(ip: str) -> bool:
    async with _rate_lock:
        if ip not in _rate_state:
            _rate_state[ip] = TokenBucket(CFG.rate_limit_burst, CFG.rate_limit_rps)
        return _rate_state[ip].allow()


def _ip_in_any(ip_str: str, nets: List[ipaddress._BaseNetwork]) -> bool:
    try:
        ip = ipaddress.ip_address(ip_str)
        return any(ip in net for net in nets)
    except ValueError:
        return False


def client_ip(request: Request) -> str:
    peer = request.client.host if request.client else "0.0.0.0"
    if CFG.trusted_proxy_cidrs and _ip_in_any(peer, CFG.trusted_proxy_cidrs):
        xff = request.headers.get("x-forwarded-for", "").strip()
        if xff:
            return xff.split(",")[0].strip()
    return peer


def cidr_allowed(ip_str: str) -> bool:
    if not CFG.allow_cidrs:
        return True
    return _ip_in_any(ip_str, CFG.allow_cidrs)


def require_bearer(auth: Optional[str]) -> None:
    if not CFG.require_bearer_token:
        return
    if not auth:
        raise HTTPException(status_code=401, detail="Missing Authorization")
    if auth.strip() != f"Bearer {CFG.require_bearer_token}":
        raise HTTPException(status_code=403, detail="Forbidden")


class PromptSanitizer:
    """Advanced prompt injection detection."""
    
    INJECTION_PATTERNS = [
        r"ignore\s+(all\s+)?previous\s+(instructions?|commands?|prompts?)",
        r"you\s+are\s+now\s+(in\s+)?\w+\s*mode",
        r"system\s*:\s*override",
        r"DAN\s*mode|Do\s+Anything\s+Now",
        r"jailbreak|developer\s+mode",
        r"<\s*/?\s*system\s*>",
        r"\[\s*system\s*\]",
    ]
    
    def __init__(self):
        import re
        self._regex = re.compile("|".join(self.INJECTION_PATTERNS), re.IGNORECASE | re.MULTILINE)
    
    def sanitize(self, text: str) -> Tuple[str, bool]:
        """Returns (sanitized_text, is_safe)."""
        if self._regex.search(text):
            return text, False
        # Truncate if extremely long
        if len(text) > CFG.max_prompt_chars:
            text = text[:CFG.max_prompt_chars] + "\n[Truncated]"
        return text, True


_sanitizer = PromptSanitizer()


# =============================================================================
# MODEL ROUTING
# =============================================================================

def choose_model(input_text: str) -> str:
    """Advanced model selection based on task analysis."""
    t = input_text.lower()
    
    # Security review tasks
    if any(k in t for k in ("security review", "threat model", "audit", "vulnerability", 
                             "vuln", "cve", "exploit", "hardening", "penetration test")):
        return CFG.model_review
    
    # Implementation tasks
    if any(k in t for k in ("implement", "patch", "diff", "fix", "bug", "refactor",
                             "unit test", "write tests", "code", "function", "class")):
        return CFG.model_impl
    
    # Architecture tasks
    if any(k in t for k in ("architecture", "design spec", "specification", "system design",
                             "rfc", "api design", "database schema", "microservice")):
        return CFG.model_arch
    
    # Default to architecture model for complex tasks
    return CFG.model_arch


def detect_task_type(prompt: str) -> str:
    """Detect the type of coding task for swarm routing."""
    p = prompt.lower()
    
    if any(k in p for k in ("security audit", "vulnerability", "exploit")):
        return "security_review"
    elif any(k in p for k in ("optimize", "performance", "slow", "memory leak")):
        return "optimization"
    elif any(k in p for k in ("refactor", "rewrite", "clean up")):
        return "refactoring"
    elif any(k in p for k in ("design", "architecture", "api")):
        return "system_design"
    elif any(k in p for k in ("test", "unittest", "pytest")):
        return "test_generation"
    else:
        return "code_generation"


# =============================================================================
# HTTP CLIENT
# =============================================================================

_http: Optional[httpx.AsyncClient] = None


async def get_http() -> httpx.AsyncClient:
    global _http
    if _http is None:
        timeout = httpx.Timeout(connect=5.0, read=CFG.router_timeout_s, write=30.0, pool=5.0)
        limits = httpx.Limits(max_connections=32, max_keepalive_connections=16)
        _http = httpx.AsyncClient(timeout=timeout, limits=limits, http2=False)
    return _http


# =============================================================================
# INPUT NORMALIZATION
# =============================================================================

def normalize_prompt(payload: Dict[str, Any]) -> Tuple[str, str]:
    """Extract and normalize prompt from various API formats."""
    
    # OpenAI Responses API
    inp = payload.get("input", "")
    if isinstance(inp, str):
        return inp.strip(), "responses"
    if isinstance(inp, list):
        parts = []
        for item in inp:
            if isinstance(item, str):
                parts.append(item)
            elif isinstance(item, dict):
                if "content" in item:
                    parts.append(str(item["content"]))
                elif "text" in item:
                    parts.append(str(item["text"]))
        return "\n".join(parts).strip(), "responses"
    
    # Chat Completions API
    msgs = payload.get("messages", [])
    if isinstance(msgs, list):
        parts = []
        for m in msgs:
            if isinstance(m, dict):
                role = m.get("role", "user")
                content = m.get("content", "")
                if isinstance(content, str):
                    parts.append(f"{role}: {content}")
                elif isinstance(content, list):
                    for c in content:
                        if isinstance(c, dict) and "text" in c:
                            parts.append(f"{role}: {c['text']}")
        return "\n".join(parts).strip(), "chat"
    
    # Legacy completions
    prompt = payload.get("prompt", "")
    if isinstance(prompt, str):
        return prompt.strip(), "completions"
    
    return str(payload), "unknown"


def extract_code_context(prompt: str) -> Dict[str, Any]:
    """Extract language and context from prompt."""
    context = {"language": "python", "framework": None}
    
    # Detect language
    lang_patterns = [
        (r"```(python|py)\b", "python"),
        (r"```(javascript|js)\b", "javascript"),
        (r"```(typescript|ts)\b", "typescript"),
        (r"```(rust|rs)\b", "rust"),
        (r"```(go|golang)\b", "go"),
        (r"```(java)\b", "java"),
        (r"```(c\+\+|cpp)\b", "cpp"),
        (r"```(ruby|rb)\b", "ruby"),
    ]
    
    for pattern, lang in lang_patterns:
        if re.search(pattern, prompt, re.IGNORECASE):
            context["language"] = lang
            break
    
    # Detect if code is included
    if "```" in prompt:
        context["has_code"] = True
        # Extract code blocks
        code_blocks = re.findall(r"```(\w+)?\n(.*?)```", prompt, re.DOTALL)
        if code_blocks:
            context["extracted_code"] = code_blocks[-1][1]  # Last code block
    
    return context


