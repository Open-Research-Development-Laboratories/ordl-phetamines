# =============================================================================
# ORDL COMMAND POST v6.0.0 - PODMAN CONTAINER IMAGE
# =============================================================================
# Classification: TOP SECRET//SCI//NOFORN
# Base: Python 3.11 with rootless container support
# =============================================================================

FROM python:3.11-slim-bookworm AS base

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    curl \
    libffi-dev \
    libssl-dev \
    sqlite3 \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20.x for MCP servers
RUN npm install -g n && n 20

# Set working directory
WORKDIR /opt/ordl

# Copy requirements first for layer caching
COPY command-post/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install MCP servers globally
RUN npm install -g \
    @modelcontextprotocol/server-github \
    @upstash/context7-mcp \
    @playwright/mcp \
    @fangjunjie/ssh-mcp-server \
    @modelcontextprotocol/server-filesystem \
    @modelcontextprotocol/server-sequential-thinking

# Install additional Python packages
RUN pip install --no-cache-dir \
    pytest \
    pytest-asyncio \
    pytest-cov \
    gunicorn \
    prometheus-client

# Production stage
FROM base AS production

# Create non-root user (Podman best practice)
RUN useradd -u 1000 -m -d /opt/ordl -s /bin/bash ordl

# Copy application code
COPY --chown=ordl:ordl command-post/ ./command-post/
COPY --chown=ordl:ordl shared/ ./shared/
COPY --chown=ordl:ordl AGENTS.md .

# Create necessary directories
RUN mkdir -p /opt/ordl/data /opt/ordl/uploads /opt/ordl/models /opt/ordl/logs \
    && chown -R ordl:ordl /opt/ordl

# Switch to non-root user
USER ordl

# Expose port
EXPOSE 18010

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:18010/health || exit 1

# Start command
WORKDIR /opt/ordl/command-post
CMD ["python3", "-m", "gunicorn", "--bind", "0.0.0.0:18010", "--workers", "4", "--timeout", "300", "backend.app_integrated:app"]
