FLEET_API_KEY=change-me-now
FLEET_API_BIND=127.0.0.1
FLEET_API_PORT=8890
FLEET_API_MAX_WORKERS=6

FLEET_SSH_USER=winsock
FLEET_SSH_PASSWORD=replace-me

FLEET_WORKSPACE_ROOT=C:\development
FLEET_REMOTE_WORKSPACE_ROOT=/development

FLEET_HUB_HOST=fleet-gateway.example.internal
FLEET_HUB_PORT=18789
FLEET_AGENT_ID=arch
FLEET_STATUS_MAX_PARALLEL=4
FLEET_HEALTH_SIGNAL_RECENCY_MINUTES=180

# Optional: named Cloudflare tunnel token for external access.
CLOUDFLARE_TUNNEL_TOKEN=

# Set true only if you want API endpoint /v1/fleet/command enabled.
FLEET_ENABLE_REMOTE_COMMAND=false
